{
  "$schema": "https://turborepo.com/schema.json",
  "globalPassThroughEnv": [
    "BASEHUB_TOKEN",
    "NEXT_PUBLIC_APP_URL",
    "NEXT_PUBLIC_WEB_URL",
    "NEXT_PUBLIC_API_URL",
    "DATABASE_URL",
    "CLERK_SECRET_KEY",
    "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
    "TURBO_TOKEN",
    "TURBO_TEAM",
    "SENTRY_ORG",
    "SENTRY_PROJECT",
    "SENTRY_AUTH_TOKEN",
    "SENTRY_ENVIRONMENT",
    "VERCEL",
    "VERCEL_ENV",
    "SKIP_ENV_VALIDATION",
    "ANALYZE",
    "NEXT_DIST_DIR"
  ],
  "globalEnv": [
    "DATABASE_URL",
    "SENTRY_ORG",
    "SENTRY_PROJECT",
    "SENTRY_AUTH_TOKEN"
  ],
  "globalDependencies": ["**/.env.*local"],
  "boundaries": {
    "tags": {
      "layer:app": {
        "dependencies": {
          "deny": ["layer:app"]
        }
      },
      "layer:package": {
        "dependencies": {
          "deny": ["layer:app"]
        }
      },
      "scope:config": {
        "dependencies": {
          "deny": [
            "layer:app",
            "scope:data",
            "scope:docs",
            "scope:integration",
            "scope:platform",
            "scope:tooling",
            "scope:ui"
          ]
        }
      },
      "scope:ui": {
        "dependencies": {
          "deny": ["layer:app", "scope:data"]
        }
      },
      "scope:data": {
        "dependents": {
          "deny": ["scope:docs", "scope:tooling", "scope:ui"]
        }
      },
      "scope:tooling": {
        "dependencies": {
          "deny": ["scope:data"]
        }
      },
      "app:client": {
        "dependencies": {
          "deny": ["app:api"]
        }
      }
    }
  },
  "ui": "tui",
  "remoteCache": {
    "enabled": true
  },
  "envMode": "loose",
  "tasks": {
    "generate": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "build": {
      "dependsOn": ["^build", "generate"],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "**/generated/**",
        "storybook-static/**",
        ".react-email/**",
        "dist/**"
      ]
    },
    "test": {
      "dependsOn": ["^test"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "cache": false
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "analyze": {
      "dependsOn": ["^build", "^analyze"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "translate": {
      "dependsOn": ["^translate"],
      "cache": false
    },
    "clean": {
      "cache": false
    },
    "//#clean": {
      "cache": false
    },
    "dev:infisical": {
      "cache": false,
      "persistent": true
    }
  }
}
