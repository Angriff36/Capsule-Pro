{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": ["src/index.{ts,tsx,js,jsx}", "src/main.{ts,tsx,js,jsx}"],
  "workspaces": {
    "packages": ["apps/*", "packages/*", "manifest/runtime"]
  },
  "duplicates": {
    "minOccurrences": 3,
    "ignore": [
      "**/lib/**",
      "**/legacy/**",
      "**/__generated__/**",
      "**/generated/**",
      "**/__tests__**"
    ],
    "mode": "mild"
  },
  "rules": {
    "unused-dependencies": "warn"
  }
}
