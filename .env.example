# Sentry (runtime + release/sourcemaps)
# NEXT_PUBLIC_SENTRY_DSN=https://...@o0.ingest.sentry.io/0
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug
# SENTRY_AUTH_TOKEN=your-auth-token
# SENTRY_ENVIRONMENT=production
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
SENTRY_ENVIRONMENT=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=

# ── Preview Deployment URLs ──────────────────────────────────────────
# These env vars control how preview deployments resolve service URLs.
# Set them in Vercel project settings (not in .env files) for each project.
#
# VERCEL_PREVIEW_URL_SUFFIX — Custom domain for all preview deploys.
#   Example: "preview.capsulepro.com"
#   When set, NEXT_PUBLIC_APP_URL and NEXT_PUBLIC_WEB_URL will use this
#   domain instead of the auto-generated Vercel preview URL.
#
# VERCEL_API_URL — The API project's hostname (without protocol).
#   Used by the app project's rewrite proxy to route /api/* requests.
#   Example: "capsule-pro-api-git-feat-xyz.vercel.app" (preview)
#            "capsule-pro-api.vercel.app" (production)
#   Set this in Vercel project settings for the APP project.
#
# VERCEL_URL — Auto-set by Vercel on every deploy. Do not set manually.
#   Used as fallback for NEXT_PUBLIC_APP_URL/WEB_URL on preview deploys.
#
# NEXT_PUBLIC_APP_URL — App frontend URL (optional override).
#   Production: "https://capsule-pro-app.vercel.app"
#   Preview: auto-derived from VERCEL_URL or VERCEL_PREVIEW_URL_SUFFIX
#   Local: "http://127.0.0.1:2221"
#
# NEXT_PUBLIC_API_URL — API server URL (optional override).
#   Production: "https://capsule-pro-api.vercel.app"
#   Preview: auto-derived from VERCEL_API_URL or VERCEL_URL
#   Local: "http://127.0.0.1:2223"

# ── Mobile (Expo) ────────────────────────────────────────────────────────
# EXPO_PUBLIC_API_URL — API URL for the mobile app (defaults to localhost:2223).
#   Production: "https://capsule-pro-api.vercel.app"
#   Local Android emulator: "http://10.0.2.2:2223"
#   Local iOS simulator: "http://localhost:2223"
EXPO_PUBLIC_API_URL=
# EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY — Clerk publishable key for native auth.
#   Falls back to NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY if unset.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# ── Twilio (SMS Notifications) ───────────────────────────────────────────
# TWILIO_ACCOUNT_SID=your-account-sid
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_PHONE_NUMBER=+1234567890
