use "../_base.manifest"
// Kitchen / Food-Safety Extended Rules
// Manifest spec for IoT temperature monitoring, HACCP logging, corrective actions,
// quality checks, task management extensions, prep tooling, and import provenance.

// ---------------------------------------------------------------------------
// TemperatureProbe — physical IoT sensor mounted in a fridge / freezer
// ---------------------------------------------------------------------------
entity TemperatureProbe mixin TenantScoped {
  key [tenantId, id]
  searchable property required name: string
  property required probeId: string
  property locationId: string = ""
  property required minTemp: decimal
  property required maxTemp: decimal
  property isActive: boolean = true
  property lastCalibration: datetime
  timestamps

  // A probe that has never been calibrated needs attention before it can be trusted.
  computed isOutOfCalibration: boolean = self.isActive == true and self.lastCalibration == null
  computed rangeSpan: decimal = self.maxTemp - self.minTemp

  constraint thresholdOrder: self.minTemp < self.maxTemp "minTemp must be less than maxTemp"
  constraint requireName: self.name != "" "Probe name is required"

  // Back-relations (U11): inverse hasMany for children that belongTo TemperatureProbe
  relationship hasMany readings: TemperatureReading
  relationship hasMany alerts: IoTAlert

  default policy TemperatureProbeDefaultAccess execute: user.role in ["staff", "kitchen_staff", "kitchen_lead", "manager", "admin"] "Kitchen extended entities"
  command create(name: string, probeId: string, optional locationId: string, minTemp: number, maxTemp: number) {
    guard name != null and name != "" "Probe name is required"
    guard probeId != null and probeId != "" "Probe hardware ID is required"
    guard minTemp < maxTemp "minTemp must be less than maxTemp"

    mutate name = name
    mutate probeId = probeId
    mutate locationId = locationId
    mutate minTemp = minTemp
    mutate maxTemp = maxTemp
    mutate isActive = true

    emit TemperatureProbeCreated
  }

  command calibrate(calibratedBy: string) {
    guard self.isActive "Cannot calibrate an inactive probe"
    guard calibratedBy != null and calibratedBy != "" "Calibrator ID is required"

    mutate lastCalibration = now()

    emit TemperatureProbeCalibrated
  }

  command updateThresholds(minTemp: number, maxTemp: number) {
    guard self.isActive "Cannot update thresholds on an inactive probe"
    guard minTemp < maxTemp "minTemp must be less than maxTemp"

    mutate minTemp = minTemp
    mutate maxTemp = maxTemp

    emit TemperatureProbeThresholdsUpdated
  }

  command deactivate(reason: string, deactivatedBy: string) {
    guard self.isActive "Probe is already inactive"

    mutate isActive = false

    emit TemperatureProbeDeactivated
  }

  store TemperatureProbe in durable
}

// ---------------------------------------------------------------------------
// TemperatureLog — manual HACCP temperature entry by staff
// ---------------------------------------------------------------------------
entity TemperatureLog mixin TenantScoped {
  key [tenantId, id]
  property required equipmentId: string
  property required logNumber: string
  property required logType: string
  property required loggedBy: string
  property required temperature: decimal
  property required loggedAt: datetime
  property required withinRange: boolean
  searchable property notes: string = ""
  timestamps

  constraint requireEquipment: self.equipmentId != "" "Equipment ID is required"
  constraint requireRecordedBy: self.loggedBy != "" "Recorder employee ID is required"

  relationship belongsTo equipment: Equipment fields [tenantId, equipmentId] references [tenantId, id]

  constraint warnOutOfRange:warn self.withinRange == false {
    messageTemplate: "Manual temperature log for equipment '{equipmentId}' is out of safe range"
    details: {
      equipmentId: self.equipmentId
      temperature: self.temperature
      loggedBy: self.loggedBy
    }
  }

  default policy TemperatureLogDefaultAccess execute: user.role in ["staff", "kitchen_staff", "kitchen_lead", "manager", "admin"] "Kitchen extended entities"
  command create(equipmentId: string, logNumber: string, logType: string, loggedBy: string, temperature: number, loggedAt: datetime, withinRange: boolean, notes: string) {
    guard equipmentId != null and equipmentId != "" "Equipment ID is required"
    guard logNumber != null and logNumber != "" "Log number is required"
    guard logType != null and logType != "" "Log type is required"
    guard loggedBy != null and loggedBy != "" "Recorder employee ID is required"

    mutate equipmentId = equipmentId
    mutate logNumber = logNumber
    mutate logType = logType
    mutate loggedBy = loggedBy
    mutate temperature = temperature
    mutate loggedAt = loggedAt
    mutate withinRange = withinRange
    mutate notes = notes

    emit TemperatureLogCreated
  }

  store TemperatureLog in durable
}

// ---------------------------------------------------------------------------
// TemperatureReading — automated timeseries reading from an IoT probe
// ---------------------------------------------------------------------------
entity TemperatureReading mixin TenantScoped {
  key [tenantId, id]
  property required probeId: string
  property required temperature: decimal
  property required loggedAt: datetime = now()
  property required withinRange: boolean
  property createdAt: datetime = now()

  constraint requireProbe: self.probeId != "" "Probe ID is required"

  relationship belongsTo probe: TemperatureProbe fields [tenantId, probeId] references [tenantId, id]

  constraint warnOutOfRange:warn self.withinRange == false {
    messageTemplate: "Automated reading from probe '{probeId}' is out of safe range"
    details: {
      probeId: self.probeId
      temperature: self.temperature
    }
  }

  default policy TemperatureReadingDefaultAccess execute: user.role in ["staff", "kitchen_staff", "kitchen_lead", "manager", "admin"] "Kitchen extended entities"
  command create(probeId: string, temperature: number, optional loggedAt: datetime, withinRange: boolean) {
    guard probeId != null and probeId != "" "Probe ID is required"

    mutate probeId = probeId
    mutate temperature = temperature
    mutate loggedAt = loggedAt
    mutate withinRange = withinRange

    emit TemperatureReadingCreated
  }

  store TemperatureReading in durable
}

// ---------------------------------------------------------------------------
// IotAlertRule — configuration for when to fire an alert on a probe/equipment
// ---------------------------------------------------------------------------
entity IotAlertRule mixin TenantScoped {
  key [tenantId, id]
  searchable property required name: string
  property required equipmentId: string
  property required sensorType: string
  property required condition: string
  property required threshold: decimal
  property thresholdMin: decimal = 0
  property thresholdMax: decimal = 0
  property required severity: string
  property durationMs: int = 0
  property alertAction: string = "notification"
  property isActive: boolean = true
  property notifyRoles: array<string> = []
  property notifyChannels: array<string> = []
  searchable property description: string = ""
  timestamps

  constraint requireEquipment: self.equipmentId != "" "Equipment ID is required"

  relationship belongsTo equipment: Equipment fields [tenantId, equipmentId] references [tenantId, id]

  // Back-relations (U11): inverse hasMany for children that belongTo IotAlertRule
  relationship hasMany alerts: IoTAlert

  constraint validCondition: self.condition in ["above", "below", "outside_range"] "Invalid condition"
  constraint requireSeverity: self.severity in ["info", "warning", "critical"] "Invalid severity level"

  default policy IotAlertRuleDefaultAccess execute: user.role in ["staff", "kitchen_staff", "kitchen_lead", "manager", "admin"] "Kitchen extended entities"
  command create(name: string, equipmentId: string, sensorType: string, condition: string, threshold: decimal, thresholdMin: decimal, thresholdMax: decimal, severity: string, durationMs: int, alertAction: string, isActive: boolean, notifyRoles: array<string>, notifyChannels: array<string>, description: string) {
    guard equipmentId != null and equipmentId != "" "Equipment ID is required"
    guard severity in ["info", "warning", "critical"] "Invalid severity level"

    mutate name = name
    mutate equipmentId = equipmentId
    mutate sensorType = sensorType
    mutate condition = condition
    mutate threshold = threshold
    mutate thresholdMin = thresholdMin
    mutate thresholdMax = thresholdMax
    mutate severity = severity
    mutate durationMs = durationMs
    mutate alertAction = alertAction
    mutate isActive = isActive
    mutate notifyRoles = notifyRoles
    mutate notifyChannels = notifyChannels
    mutate description = description

    emit IotAlertRuleCreated
  }

  command update(threshold: number, severity: string) {
    guard self.isActive "Cannot update an inactive alert rule"
    guard severity in ["info", "warning", "critical"] "Invalid severity level"

    mutate threshold = threshold
    mutate severity = severity

    emit IotAlertRuleUpdated
  }

  command deactivate(reason: string, deactivatedBy: string) {
    guard self.isActive "Alert rule is already inactive"

    mutate isActive = false

    emit IotAlertRuleDeactivated
  }

  store IotAlertRule in durable
}

// ---------------------------------------------------------------------------
// IoTAlert — a fired alert from a probe breaching a rule
// ---------------------------------------------------------------------------
entity IoTAlert mixin TenantScoped {
  key [tenantId, id]
  property required probeId: string
  property ruleId: string = ""
  property required severity: string
  property required message: string
  property required value: decimal
  indexed property required status: string = "active"
  property required triggeredAt: datetime
  property alertNumber: string = ""
  property alertType: string = ""
  searchable property title: string = ""
  property temperature: decimal = 0
  property acknowledgedBy: string = ""
  property resolvedBy: string = ""
  timestamps

  computed isActive: boolean = self.status == "active"
  computed isAcknowledged: boolean = self.status == "acknowledged"
  computed isResolved: boolean = self.status == "resolved"

  constraint validStatus: self.status in ["active", "acknowledged", "resolved"] "Invalid alert status"
  constraint validSeverity: self.severity in ["info", "warning", "critical"] "Invalid severity level"
  constraint requireMessage: self.message != "" "Alert message is required"

  // State transitions
  transition status from "active" to ["acknowledged", "resolved"]
  transition status from "acknowledged" to ["resolved"]

  relationship belongsTo probe: TemperatureProbe fields [tenantId, probeId] references [tenantId, id]
  relationship belongsTo rule: IotAlertRule fields [tenantId, ruleId] references [tenantId, id]

  default policy IoTAlertDefaultAccess execute: user.role in ["staff", "kitchen_staff", "kitchen_lead", "manager", "admin"] "Kitchen extended entities"
  command create(probeId: string, ruleId: string, severity: string, message: string, value: decimal, triggeredAt: datetime, alertNumber: string, alertType: string, title: string, temperature: decimal) {
    guard probeId != null and probeId != "" "Probe ID is required"
    guard severity in ["info", "warning", "critical"] "Invalid severity level"
    guard message != null and message != "" "Alert message is required"

    mutate probeId = probeId
    mutate ruleId = ruleId
    mutate severity = severity
    mutate message = message
    mutate value = value
    mutate triggeredAt = triggeredAt
    mutate alertNumber = alertNumber
    mutate alertType = alertType
    mutate title = title
    mutate temperature = temperature

    emit IoTAlertCreated
  }

  command acknowledge(acknowledgedBy: string) {
    guard self.status == "active" "Only active alerts can be acknowledged"
    guard acknowledgedBy != null and acknowledgedBy != "" "Acknowledger employee ID is required"

    mutate status = "acknowledged"
    mutate acknowledgedBy = acknowledgedBy

    emit IoTAlertAcknowledged
  }

  command markResolved(resolvedBy: string) {
    guard self.status in ["active", "acknowledged"] "Only active or acknowledged alerts can be resolved"
    guard resolvedBy != null and resolvedBy != "" "Resolver employee ID is required"

    mutate status = "resolved"
    mutate resolvedBy = resolvedBy

    emit IoTAlertResolved
  }

  store IoTAlert in durable
}

// ---------------------------------------------------------------------------
// CorrectiveAction — food-safety corrective action after a quality/temp failure
// ---------------------------------------------------------------------------
entity CorrectiveAction mixin TenantScoped {
  key [tenantId, id]
  property required actionNumber: string
  property required title: string
  property required sourceType: string
  property required sourceId: string
  searchable property required description: string
  property assignedTo: string = ""
  indexed property required status: string = "open"
  property dueDate: datetime
  property resolvedAt: datetime
  timestamps

  computed isOpen: boolean = self.status == "open"
  computed isInProgress: boolean = self.status == "in_progress"
  computed isClosed: boolean = self.status == "closed"

  transition status from "open" to ["in_progress", "closed"]
  transition status from "in_progress" to ["closed"]

  constraint validStatus: self.status in ["open", "in_progress", "closed"] "Invalid corrective action status"
  constraint requireSourceType: self.sourceType != "" "Source type is required"
  constraint requireSourceId: self.sourceId != "" "Source ID is required"
  constraint requireDescription: self.description != "" "Description is required"

  default policy CorrectiveActionDefaultAccess execute: user.role in ["staff", "kitchen_staff", "kitchen_lead", "manager", "admin"] "Kitchen extended entities"
  command create(actionNumber: string, title: string, sourceType: string, sourceId: string, description: string, dueDate: datetime) {
    guard actionNumber != null and actionNumber != "" "Action number is required"
    guard title != null and title != "" "Title is required"
    guard sourceType != null and sourceType != "" "Source type is required"
    guard sourceId != null and sourceId != "" "Source ID is required"
    guard description != null and description != "" "Description is required"

    mutate actionNumber = actionNumber
    mutate title = title
    mutate sourceType = sourceType
    mutate sourceId = sourceId
    mutate description = description
    mutate dueDate = dueDate

    emit CorrectiveActionCreated
  }

  command assign(assignedTo: string, assignedBy: string) {
    guard self.status != "closed" "Cannot assign a closed corrective action"
    guard assignedTo != null and assignedTo != "" "Assignee employee ID is required"

    mutate assignedTo = assignedTo

    emit CorrectiveActionAssigned
  }

  command startProgress(startedBy: string) {
    guard self.status == "open" "Corrective action must be open to start progress"

    mutate status = "in_progress"

    emit CorrectiveActionStarted
  }

  command close(resolvedBy: string, resolutionNotes: string) {
    guard self.status in ["open", "in_progress"] "Cannot close an already-closed corrective action"
    guard resolvedBy != null and resolvedBy != "" "Resolver employee ID is required"

    mutate status = "closed"
    mutate resolvedAt = now()

    emit CorrectiveActionClosed
  }

  store CorrectiveAction in durable
}

// ---------------------------------------------------------------------------
// QualityCheck — a food-safety quality check (receiving, cooling, etc.)
// ---------------------------------------------------------------------------
entity QualityCheck mixin TenantScoped {
  key [tenantId, id]
  property required checkNumber: string
  property required title: string
  property required checkType: string
  property required completedBy: string
  indexed property required status: string = "pending"
  property completedAt: datetime
  searchable property notes: string = ""
  timestamps

  computed isPending: boolean = self.status == "pending"
  computed isPassed: boolean = self.status == "passed"
  computed isFailed: boolean = self.status == "failed"

  relationship hasMany items: QualityCheckItem

  transition status from "pending" to ["passed", "failed"]
  transition status from "passed" to ["pending"]
  transition status from "failed" to ["pending"]

  constraint validStatus: self.status in ["pending", "passed", "failed"] "Invalid quality check status"
  constraint requireCheckType: self.checkType != "" "Check type is required"
  constraint requirePerformedBy: self.completedBy != "" "Performer employee ID is required"

  default policy QualityCheckDefaultAccess execute: user.role in ["staff", "kitchen_staff", "kitchen_lead", "manager", "admin"] "Kitchen extended entities"
  command create(checkNumber: string, title: string, checkType: string, completedBy: string, notes: string) {
    guard checkNumber != null and checkNumber != "" "Check number is required"
    guard title != null and title != "" "Title is required"
    guard checkType != null and checkType != "" "Check type is required"
    guard completedBy != null and completedBy != "" "Performer employee ID is required"

    mutate checkNumber = checkNumber
    mutate title = title
    mutate checkType = checkType
    mutate completedBy = completedBy
    mutate notes = notes

    emit QualityCheckCreated
  }

  command pass(passedBy: string, notes: string) {
    guard self.status == "pending" "Quality check must be pending to pass"

    mutate status = "passed"
    mutate completedAt = now()
    mutate notes = notes

    emit QualityCheckPassed
  }

  command fail(failedBy: string, notes: string) {
    guard self.status == "pending" "Quality check must be pending to fail"
    guard notes != null and notes != "" "Failure notes are required"

    mutate status = "failed"
    mutate completedAt = now()
    mutate notes = notes

    emit QualityCheckFailed
  }

  command reinspect(requestedBy: string, reason: string) {
    guard self.status in ["passed", "failed"] "Only a completed quality check can be re-inspected"
    guard requestedBy != null and requestedBy != "" "Requester employee ID is required"

    mutate status = "pending"
    mutate notes = reason

    emit QualityCheckReinspected
  }

  store QualityCheck in durable
}

// ---------------------------------------------------------------------------
// QualityCheckItem — an individual criterion within a QualityCheck
// ---------------------------------------------------------------------------
entity QualityCheckItem mixin TenantScoped {
  key [tenantId, id]
  property required checkId: string
  property required itemName: string
  property required criterion: string
  property passed: boolean = false
  searchable property notes: string = ""
  property sortOrder: int = 0
  timestamps

  constraint requireQualityCheckId: self.checkId != "" "Quality check ID is required"

  relationship belongsTo qualityCheck: QualityCheck fields [tenantId, checkId] references [tenantId, id]

  constraint requireCriterion: self.criterion != "" "Criterion description is required"
  constraint positiveSortOrder: self.sortOrder >= 0 "Sort order cannot be negative"

  default policy QualityCheckItemDefaultAccess execute: user.role in ["staff", "kitchen_staff", "kitchen_lead", "manager", "admin"] "Kitchen extended entities"
  command create(checkId: string, itemName: string, criterion: string, sortOrder: number) {
    guard checkId != null and checkId != "" "Quality check ID is required"
    guard itemName != null and itemName != "" "Item name is required"
    guard criterion != null and criterion != "" "Criterion description is required"
    guard sortOrder >= 0 "Sort order cannot be negative"

    mutate checkId = checkId
    mutate itemName = itemName
    mutate criterion = criterion
    mutate passed = false
    mutate sortOrder = sortOrder

    emit QualityCheckItemCreated
  }

  command recordResult(passed: boolean, notes: string, recordedBy: string) {
    guard recordedBy != null and recordedBy != "" "Recorder employee ID is required"

    mutate passed = passed
    mutate notes = notes

    emit QualityCheckItemResultRecorded
  }

  store QualityCheckItem in durable
}

// ---------------------------------------------------------------------------
// KitchenTaskClaim — an employee claiming a kitchen task
// ---------------------------------------------------------------------------
entity KitchenTaskClaim mixin TenantScoped {
  key [tenantId, id]
  property required taskId: string
  property required employeeId: string
  property required claimedAt: datetime
  indexed property required status: string = "active"
  property releasedAt: datetime
  property releaseReason: string = ""
  timestamps

  computed isActive: boolean = self.status == "active"
  computed isReleased: boolean = self.status == "released"

  transition status from "active" to ["released"]

  constraint validStatus: self.status in ["active", "released"] "Invalid claim status"
  constraint requireKitchenTaskId: self.taskId != "" "Kitchen task ID is required"
  constraint requireEmployeeId: self.employeeId != "" "Employee ID is required"

  relationship belongsTo kitchenTask: KitchenTask fields [tenantId, taskId] references [tenantId, id]
  relationship belongsTo employee: User fields [tenantId, employeeId] references [tenantId, id]

  default policy KitchenTaskClaimDefaultAccess execute: user.role in ["staff", "kitchen_staff", "kitchen_lead", "manager", "admin"] "Kitchen extended entities"
  command claim(taskId: string, employeeId: string, claimedAt: datetime) {
    guard taskId != null and taskId != "" "Kitchen task ID is required"
    guard employeeId != null and employeeId != "" "Employee ID is required"

    mutate taskId = taskId
    mutate employeeId = employeeId
    mutate claimedAt = claimedAt
    mutate status = "active"

    emit KitchenTaskClaimCreated
  }

  command release(releasedBy: string, reason: string) {
    guard self.status == "active" "Only an active claim can be released"
    guard releasedBy != null and releasedBy != "" "Releaser employee ID is required"

    mutate status = "released"
    mutate releasedAt = now()
    mutate releaseReason = reason

    emit KitchenTaskClaimReleased
  }

  store KitchenTaskClaim in durable
}

// ---------------------------------------------------------------------------
// KitchenTaskProgress — a progress / status update snapshot on a kitchen task
// ---------------------------------------------------------------------------
entity KitchenTaskProgress mixin TenantScoped {
  key [tenantId, id]
  property required taskId: string
  property required employeeId: string
  property required progressType: string
  indexed property required newStatus: string
  property required progressPct: decimal
  property notes: string = ""
  property required recordedAt: datetime
  property createdAt: datetime = now()

  constraint requireKitchenTaskId: self.taskId != "" "Kitchen task ID is required"
  constraint requireEmployeeId: self.employeeId != "" "Employee ID is required"
  constraint validProgressPct: self.progressPct >= 0 and self.progressPct <= 100 "Progress percentage must be between 0 and 100"

  relationship belongsTo kitchenTask: KitchenTask fields [tenantId, taskId] references [tenantId, id]
  relationship belongsTo employee: User fields [tenantId, employeeId] references [tenantId, id]

  default policy KitchenTaskProgressDefaultAccess execute: user.role in ["staff", "kitchen_staff", "kitchen_lead", "manager", "admin"] "Kitchen extended entities"
  command create(taskId: string, employeeId: string, progressType: string, newStatus: string, progressPct: number, notes: string, recordedAt: datetime) {
    guard taskId != null and taskId != "" "Kitchen task ID is required"
    guard employeeId != null and employeeId != "" "Employee ID is required"
    guard progressType != null and progressType != "" "Progress type is required"
    guard newStatus != null and newStatus != "" "Status is required"
    guard progressPct >= 0 and progressPct <= 100 "Progress percentage must be between 0 and 100"

    mutate taskId = taskId
    mutate employeeId = employeeId
    mutate progressType = progressType
    mutate newStatus = newStatus
    mutate progressPct = progressPct
    mutate notes = notes
    mutate recordedAt = recordedAt

    emit KitchenTaskProgressRecorded
  }

  store KitchenTaskProgress in durable
}

// ---------------------------------------------------------------------------
// TaskBundle — a named grouping of kitchen tasks, optionally event-scoped
// ---------------------------------------------------------------------------
entity TaskBundle mixin TenantScoped {
  key [tenantId, id]
  searchable property required name: string
  property eventId: string = ""
  searchable property description: string = ""
  indexed property required status: string = "active"
  timestamps

  computed isArchived: boolean = self.status == "archived"
  computed isActive: boolean = self.status == "active"

  relationship hasMany items: TaskBundleItem
  relationship belongsTo event: Event fields [tenantId, eventId] references [tenantId, id]

  transition status from "active" to ["archived"]

  constraint validStatus: self.status in ["active", "archived"] "Invalid bundle status"
  constraint requireName: self.name != "" "Task bundle name is required"

  default policy TaskBundleDefaultAccess execute: user.role in ["staff", "kitchen_staff", "kitchen_lead", "manager", "admin"] "Kitchen extended entities"
  command create(name: string, eventId: string, description: string) {
    guard name != null and name != "" "Task bundle name is required"

    mutate name = name
    mutate eventId = eventId
    mutate description = description

    emit TaskBundleCreated
  }

  command update(name: string, description: string) {
    guard self.status == "active" "Cannot update an archived task bundle"
    guard name != null and name != "" "Task bundle name is required"

    mutate name = name
    mutate description = description

    emit TaskBundleUpdated
  }

  command archive(archivedBy: string, reason: string) {
    guard self.status == "active" "Task bundle is already archived"

    mutate status = "archived"

    emit TaskBundleArchived
  }

  store TaskBundle in durable
}

// ---------------------------------------------------------------------------
// TaskBundleItem — a kitchen task within a bundle
// ---------------------------------------------------------------------------
entity TaskBundleItem mixin TenantScoped {
  key [tenantId, id]
  property required taskBundleId: string
  property required kitchenTaskId: string
  property sortOrder: int = 0
  timestamps

  constraint requireTaskBundleId: self.taskBundleId != "" "Task bundle ID is required"
  constraint requireKitchenTaskId: self.kitchenTaskId != "" "Kitchen task ID is required"
  constraint positiveSortOrder: self.sortOrder >= 0 "Sort order cannot be negative"

  relationship belongsTo taskBundle: TaskBundle fields [tenantId, taskBundleId] references [tenantId, id]
  relationship belongsTo kitchenTask: KitchenTask fields [tenantId, kitchenTaskId] references [tenantId, id]

  default policy TaskBundleItemDefaultAccess execute: user.role in ["staff", "kitchen_staff", "kitchen_lead", "manager", "admin"] "Kitchen extended entities"
  command addItem(taskBundleId: string, kitchenTaskId: string, sortOrder: number) {
    guard taskBundleId != null and taskBundleId != "" "Task bundle ID is required"
    guard kitchenTaskId != null and kitchenTaskId != "" "Kitchen task ID is required"
    guard sortOrder >= 0 "Sort order cannot be negative"

    mutate taskBundleId = taskBundleId
    mutate kitchenTaskId = kitchenTaskId
    mutate sortOrder = sortOrder

    emit TaskBundleItemAdded
  }

  command removeItem(removedBy: string, reason: string) {
    guard removedBy != null and removedBy != "" "Remover employee ID is required"


    emit TaskBundleItemRemoved
  }

  store TaskBundleItem in durable
}

// ---------------------------------------------------------------------------
// BulkCombineRule — rule to auto-combine similar prep tasks into a single job
// ---------------------------------------------------------------------------
entity BulkCombineRule mixin TenantScoped {
  key [tenantId, id]
  searchable property required name: string
  property required matchCriteria: string
  property isActive: boolean = true
  timestamps

  constraint requireName: self.name != "" "Bulk combine rule name is required"
  constraint requireMatchCriteria: self.matchCriteria != "" "Match criteria is required"

  default policy BulkCombineRuleDefaultAccess execute: user.role in ["staff", "kitchen_staff", "kitchen_lead", "manager", "admin"] "Kitchen extended entities"
  command create(name: string, matchCriteria: string) {
    guard name != null and name != "" "Bulk combine rule name is required"
    guard matchCriteria != null and matchCriteria != "" "Match criteria is required"

    mutate name = name
    mutate matchCriteria = matchCriteria
    mutate isActive = true

    emit BulkCombineRuleCreated
  }

  command update(name: string, matchCriteria: string) {
    guard self.isActive "Cannot update an inactive bulk combine rule"
    guard name != null and name != "" "Bulk combine rule name is required"
    guard matchCriteria != null and matchCriteria != "" "Match criteria is required"

    mutate name = name
    mutate matchCriteria = matchCriteria

    emit BulkCombineRuleUpdated
  }

  command deactivate(reason: string, deactivatedBy: string) {
    guard self.isActive "Bulk combine rule is already inactive"

    mutate isActive = false

    emit BulkCombineRuleDeactivated
  }

  store BulkCombineRule in durable
}

// ---------------------------------------------------------------------------
// MethodVideo — instructional video attached to a prep method
// ---------------------------------------------------------------------------
entity MethodVideo mixin TenantScoped {
  key [tenantId, id]
  property required prepMethodId: string
  searchable property required title: string
  property required url: string
  property durationSeconds: int = 0
  timestamps

  constraint requirePrepMethodId: self.prepMethodId != "" "Prep method ID is required"

  relationship belongsTo prepMethod: PrepMethod fields [tenantId, prepMethodId] references [tenantId, id]

  constraint requireTitle: self.title != "" "Video title is required"
  constraint requireUrl: self.url != "" "Video URL is required"
  constraint positiveDuration: self.durationSeconds >= 0 "Duration cannot be negative"

  default policy MethodVideoDefaultAccess execute: user.role in ["staff", "kitchen_staff", "kitchen_lead", "manager", "admin"] "Kitchen extended entities"
  command create(prepMethodId: string, title: string, url: string, durationSeconds: number) {
    guard prepMethodId != null and prepMethodId != "" "Prep method ID is required"
    guard title != null and title != "" "Video title is required"
    guard url != null and url != "" "Video URL is required"
    guard durationSeconds >= 0 "Duration cannot be negative"

    mutate prepMethodId = prepMethodId
    mutate title = title
    mutate url = url
    mutate durationSeconds = durationSeconds

    emit MethodVideoCreated
  }

  command update(title: string, url: string, durationSeconds: number) {
    guard title != null and title != "" "Video title is required"
    guard url != null and url != "" "Video URL is required"
    guard durationSeconds >= 0 "Duration cannot be negative"

    mutate title = title
    mutate url = url
    mutate durationSeconds = durationSeconds

    emit MethodVideoUpdated
  }

  command remove(removedBy: string, reason: string) {
    guard removedBy != null and removedBy != "" "Remover employee ID is required"


    emit MethodVideoRemoved
  }

  store MethodVideo in durable
}

// ---------------------------------------------------------------------------
// PrepListImport — provenance record for an imported prep list
// ---------------------------------------------------------------------------
entity PrepListImport mixin TenantScoped {
  key [tenantId, id]
  property required source: string
  property required fileName: string
  indexed property required status: string = "pending"
  property importedAt: datetime
  property errorMessage: string = ""
  timestamps

  computed isPending: boolean = self.status == "pending"
  computed isComplete: boolean = self.status == "complete"
  computed isFailed: boolean = self.status == "failed"

  transition status from "pending" to ["complete", "failed"]

  constraint validStatus: self.status in ["pending", "complete", "failed"] "Invalid import status"
  constraint requireSource: self.source != "" "Import source is required"
  constraint requireFileName: self.fileName != "" "File name is required"

  default policy PrepListImportDefaultAccess execute: user.role in ["staff", "kitchen_staff", "kitchen_lead", "manager", "admin"] "Kitchen extended entities"
  command create(source: string, fileName: string) {
    guard source != null and source != "" "Import source is required"
    guard fileName != null and fileName != "" "File name is required"

    mutate source = source
    mutate fileName = fileName

    emit PrepListImportCreated
  }

  command complete(rowsImported: number) {
    guard self.status == "pending" "Import must be pending to complete"

    mutate status = "complete"
    mutate importedAt = now()

    emit PrepListImportCompleted
  }

  command fail(errorMessage: string) {
    guard self.status == "pending" "Import must be pending to fail"
    guard errorMessage != null and errorMessage != "" "Error message is required"

    mutate status = "failed"
    mutate errorMessage = errorMessage

    emit PrepListImportFailed
  }

  store PrepListImport in durable
}

// ---------------------------------------------------------------------------
// Policies
// ---------------------------------------------------------------------------
policy KitchenStaffCanViewReadings execute: user.role in ["kitchen_staff", "kitchen_lead", "manager", "admin"] "Kitchen staff can view temperature readings"
policy ManagersCanManageProbes execute: user.role in ["kitchen_lead", "manager", "admin"] "Managers can manage temperature probes"
policy ManagersCanManageAlertRules execute: user.role in ["kitchen_lead", "manager", "admin"] "Managers can manage IoT alert rules"
policy KitchenStaffCanLogTemperature execute: user.role in ["kitchen_staff", "kitchen_lead", "manager", "admin"] "Kitchen staff can log manual temperature readings"
policy KitchenStaffCanPerformQualityChecks execute: user.role in ["kitchen_staff", "kitchen_lead", "manager", "admin"] "Kitchen staff can perform quality checks"
policy ManagersCanManageCorrectiveActions execute: user.role in ["kitchen_lead", "manager", "admin"] "Managers can manage corrective actions"
policy KitchenStaffCanUpdateProgress execute: user.role in ["kitchen_staff", "kitchen_lead", "manager", "admin"] "Kitchen staff can record task progress"
policy ManagersCanManageBundles execute: user.role in ["kitchen_lead", "manager", "admin"] "Managers can manage task bundles"
policy ManagersCanManageCombineRules execute: user.role in ["kitchen_lead", "manager", "admin"] "Managers can manage bulk combine rules"
policy ManagersCanManageMethodVideos execute: user.role in ["kitchen_lead", "manager", "admin"] "Managers can manage method videos"
policy ManagersCanManageImports execute: user.role in ["kitchen_lead", "manager", "admin"] "Managers can manage prep list imports"

