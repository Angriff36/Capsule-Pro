entity SelOnboardingTrainingQuestion06Definition {
  key [tenantId, id]

  indexed property required tenantId: string
  property required id: string
  property questionId: string = "sel-event-staff-onboarding-q6"
  property moduleId: string = "training-module-sel-event-staff-onboarding"
  property code: string = "Q6"
  property sectionTitle: string = "Pre-Event Workflow"
  property displayOrder: int = 6
  property prompt: string = "Put the pre-event steps in the correct order:"
  property optionA: string = "Badge → Clock in → Arrive → Meet crew"
  property optionB: string = "Arrive → Clock in → Badge → Meet crew"
  property optionC: string = "Arrive → Badge → Clock in → Meet crew"
  property optionD: string = "Clock in → Arrive → Badge → Meet crew"
  property correctOptionKey: string = "B"
  property explanation: string = "The correct order is Arrive → Clock in → Badge → Meet crew."
  property whyItMatters: string = "The sequence matters for timekeeping, access, and crew readiness."

  timestamps

  default policy SelOnboardingTrainingQuestion06Access execute: user.role in ["admin", "manager", "system"]

  command create() {
    emit SelOnboardingTrainingQuestionDefinitionCreated
  }

  relationship belongsTo question: TrainingQuestion with questionId
  relationship belongsTo module: TrainingModule with moduleId

  store in memory
}

entity SelOnboardingTrainingQuestion07Definition {
  key [tenantId, id]

  indexed property required tenantId: string
  property required id: string
  property questionId: string = "sel-event-staff-onboarding-q7"
  property moduleId: string = "training-module-sel-event-staff-onboarding"
  property code: string = "Q7"
  property sectionTitle: string = "Pre-Event Workflow"
  property displayOrder: int = 7
  property prompt: string = "When do you clock in on Nowsta?"
  property optionA: string = "After you pick up your badge"
  property optionB: string = "When the BOH Lead arrives"
  property optionC: string = "At your scheduled start time when you arrive on site"
  property optionD: string = "When service begins"
  property correctOptionKey: string = "C"
  property explanation: string = "Clock in at your scheduled start time when you arrive on site."
  property whyItMatters: string = "Nowsta timekeeping starts when you are on site and ready to work."

  timestamps

  default policy SelOnboardingTrainingQuestion07Access execute: user.role in ["admin", "manager", "system"]

  command create() {
    emit SelOnboardingTrainingQuestionDefinitionCreated
  }

  relationship belongsTo question: TrainingQuestion with questionId
  relationship belongsTo module: TrainingModule with moduleId

  store in memory
}

entity SelOnboardingTrainingQuestion08Definition {
  key [tenantId, id]

  indexed property required tenantId: string
  property required id: string
  property questionId: string = "sel-event-staff-onboarding-q8"
  property moduleId: string = "training-module-sel-event-staff-onboarding"
  property code: string = "Q8"
  property sectionTitle: string = "Buffet Service"
  property displayOrder: int = 8
  property prompt: string = "During buffet service, which portion do Mangia staff always serve?"
  property optionA: string = "Side dishes only"
  property optionB: string = "Everything equally"
  property optionC: string = "The protein"
  property optionD: string = "Whatever the BOH Lead decides on the day"
