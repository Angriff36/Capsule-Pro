use "./training-module-rules.manifest"

event StaffMemberCreated: "staff.member.created" {
  staffMemberId: string
  role: string
  firstShiftAt: datetime
  dueAt: datetime
}

event StaffMemberFirstShiftScheduled: "staff.member.first-shift-scheduled" {
  staffMemberId: string
  firstShiftAt: datetime
  dueAt: datetime
}

event SelOnboardingTrainingDefinitionCreated: "training.sel-onboarding.definition-created" {
  id: string
}

event SelOnboardingTrainingQuestionDefinitionCreated: "training.sel-onboarding.question-definition-created" {
  id: string
}

entity SelOnboardingTrainingModuleDefinition {
  key [tenantId, id]

  indexed property required tenantId: string
  property required id: string
  property moduleId: string = "training-module-sel-event-staff-onboarding"
  property code: string = "sel_event_staff_onboarding"
  searchable property title: string = "SEL Event Staff — Onboarding Training"
  searchable property description: string = "Required pre-shift training for all Mangia staff working SEL Friday Lunch events. Covers client context, compliance requirements, pre-event workflow, buffet service, and wrap-up procedures. Must be completed before first shift."
  property contentType: string = "interactive"
  property contentUrl: string = "TBD"
  property durationMinutes: int = 20
  property category: string = "onboarding"
  property isRequired: boolean = true
  property passThresholdPercent: int = 80
  property maxAttempts: int = 3
  property requiredRole: string = "staff"

  timestamps

  default policy SelOnboardingTrainingModuleDefinitionAccess execute: user.role in ["admin", "manager", "system"]

  command create() {
    emit SelOnboardingTrainingDefinitionCreated
  }

  relationship belongsTo module: TrainingModule with moduleId

  store in memory
}

entity SelOnboardingTrainingQuestion01Definition {
  key [tenantId, id]

  indexed property required tenantId: string
  property required id: string
  property questionId: string = "sel-event-staff-onboarding-q1"
  property moduleId: string = "training-module-sel-event-staff-onboarding"
  property code: string = "Q1"
  property sectionTitle: string = "Context"
  property displayOrder: int = 1
  property prompt: string = "Mangia is SEL's only catering vendor on Friday Lunch events."
  property optionA: string = "True"
  property optionB: string = "False"
  property optionC: string = ""
  property optionD: string = ""
  property correctOptionKey: string = "B"
  property explanation: string = "False. Mangia is not SEL's only Friday Lunch vendor."
  property whyItMatters: string = "Staff need to understand we earn our spot."

  timestamps

  default policy SelOnboardingTrainingQuestion01Access execute: user.role in ["admin", "manager", "system"]

  command create() {
    emit SelOnboardingTrainingQuestionDefinitionCreated
  }

  relationship belongsTo question: TrainingQuestion with questionId
  relationship belongsTo module: TrainingModule with moduleId

  store in memory
}

entity SelOnboardingTrainingQuestion02Definition {
  key [tenantId, id]

  indexed property required tenantId: string
  property required id: string
  property questionId: string = "sel-event-staff-onboarding-q2"
  property moduleId: string = "training-module-sel-event-staff-onboarding"
  property code: string = "Q2"
  property sectionTitle: string = "Context"
  property displayOrder: int = 2
  property prompt: string = "What is SEL's primary reason for choosing Mangia over other vendors?"
  property optionA: string = "We are the cheapest option"
  property optionB: string = "We are the closest to campus"
  property optionC: string = "Professionalism, quality, and consistency"
  property optionD: string = "We have the most staff available"
  property correctOptionKey: string = "C"
  property explanation: string = "SEL chooses Mangia for professionalism, quality, and consistency."
  property whyItMatters: string = "This is the service standard every SEL shift must reinforce."

  timestamps

  default policy SelOnboardingTrainingQuestion02Access execute: user.role in ["admin", "manager", "system"]

  command create() {
    emit SelOnboardingTrainingQuestionDefinitionCreated
  }

  relationship belongsTo question: TrainingQuestion with questionId
  relationship belongsTo module: TrainingModule with moduleId

  store in memory
}

entity SelOnboardingTrainingQuestion03Definition {
  key [tenantId, id]

  indexed property required tenantId: string
  property required id: string
  property questionId: string = "sel-event-staff-onboarding-q3"
  property moduleId: string = "training-module-sel-event-staff-onboarding"
  property code: string = "Q3"
  property sectionTitle: string = "Compliance"
  property displayOrder: int = 3
  property prompt: string = "Your WA State Food Worker Card must be current..."
  property optionA: string = "Within 30 days of your first shift"
  property optionB: string = "Before your first shift"
  property optionC: string = "Within your first week"
  property optionD: string = "By the end of your first month"
  property correctOptionKey: string = "B"
  property explanation: string = "Your WA State Food Worker Card must be current before your first shift."
  property whyItMatters: string = "No current card means you are not shift-ready."

  timestamps

  default policy SelOnboardingTrainingQuestion03Access execute: user.role in ["admin", "manager", "system"]

  command create() {
    emit SelOnboardingTrainingQuestionDefinitionCreated
  }

  relationship belongsTo question: TrainingQuestion with questionId
  relationship belongsTo module: TrainingModule with moduleId

  store in memory
}

entity SelOnboardingTrainingQuestion04Definition {
  key [tenantId, id]

  indexed property required tenantId: string
  property required id: string
  property questionId: string = "sel-event-staff-onboarding-q4"
  property moduleId: string = "training-module-sel-event-staff-onboarding"
  property code: string = "Q4"
  property sectionTitle: string = "Compliance"
  property displayOrder: int = 4
  property prompt: string = "Where do you pick up your SEL visitor badge?"
  property optionA: string = "At your assigned building"
  property optionB: string = "At the Mangia vehicle"
  property optionC: string = "At Building One security desk"
  property optionD: string = "The BOH Lead brings it to you"
  property correctOptionKey: string = "C"
  property explanation: string = "Pick up the badge at Building One security desk."
  property whyItMatters: string = "Arriving at the right check-in point prevents delays."

  timestamps

  default policy SelOnboardingTrainingQuestion04Access execute: user.role in ["admin", "manager", "system"]

  command create() {
    emit SelOnboardingTrainingQuestionDefinitionCreated
  }

  relationship belongsTo question: TrainingQuestion with questionId
  relationship belongsTo module: TrainingModule with moduleId

  store in memory
}

entity SelOnboardingTrainingQuestion05Definition {
  key [tenantId, id]

  indexed property required tenantId: string
  property required id: string
  property questionId: string = "sel-event-staff-onboarding-q5"
  property moduleId: string = "training-module-sel-event-staff-onboarding"
  property code: string = "Q5"
  property sectionTitle: string = "Compliance"
  property displayOrder: int = 5
  property prompt: string = "Where must your visitor badge be worn at all times on SEL campus?"
  property optionA: string = "In your pocket for safekeeping"
  property optionB: string = "Clipped to your bag"
  property optionC: string = "Above the waistline, visible at all times"
  property optionD: string = "Anywhere comfortable"
  property correctOptionKey: string = "C"
  property explanation: string = "Wear the badge above the waistline and keep it visible."
  property whyItMatters: string = "Campus badge rules are mandatory, not optional."

  timestamps

  default policy SelOnboardingTrainingQuestion05Access execute: user.role in ["admin", "manager", "system"]

