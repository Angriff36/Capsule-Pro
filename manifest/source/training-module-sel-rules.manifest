entity SelOnboardingTrainingQuestion09Definition {
  key [tenantId, id]

  indexed property required tenantId: string
  property required id: string
  property questionId: string = "sel-event-staff-onboarding-q9"
  property moduleId: string = "training-module-sel-event-staff-onboarding"
  property code: string = "Q9"
  property sectionTitle: string = "Buffet Service"
  property displayOrder: int = 9
  property prompt: string = "What is the typical staffing configuration per buffet line?"
  property optionA: string = "1 Server + 1 Runner"
  property optionB: string = "3 Servers"
  property optionC: string = "2 Servers + 1 Runner"
  property optionD: string = "2 Runners + 1 Server"
  property correctOptionKey: string = "C"
  property explanation: string = "A typical line uses 2 Servers and 1 Runner."
  property whyItMatters: string = "Knowing the standard line build helps staff slot in quickly."

  timestamps

  default policy SelOnboardingTrainingQuestion09Access execute: user.role in ["admin", "manager", "system"]

  command create() {
    emit SelOnboardingTrainingQuestionDefinitionCreated
  }

  relationship belongsTo question: TrainingQuestion with questionId
  relationship belongsTo module: TrainingModule with moduleId

  store in memory
}

entity SelOnboardingTrainingQuestion10Definition {
  key [tenantId, id]

  indexed property required tenantId: string
  property required id: string
  property questionId: string = "sel-event-staff-onboarding-q10"
  property moduleId: string = "training-module-sel-event-staff-onboarding"
  property code: string = "Q10"
  property sectionTitle: string = "Wrap-Up"
  property displayOrder: int = 10
  property prompt: string = "Which of the following is the correct final checkout sequence?"
  property optionA: string = "Clock out → Return badge → Sign out → Check in with BOH Lead"
  property optionB: string = "Check in with BOH Lead → Sign out of staff sheet → Return SEL badge → Clock out of Nowsta"
  property optionC: string = "Return badge → Clock out → Sign out → Check in with BOH Lead"
  property optionD: string = "Sign out → Return badge → Check in with BOH Lead → Clock out"
  property correctOptionKey: string = "B"
  property explanation: string = "The correct sequence is Check in with BOH Lead → Sign out → Return badge → Clock out."
  property whyItMatters: string = "The checkout order closes accountability and campus access correctly."

  timestamps

  default policy SelOnboardingTrainingQuestion10Access execute: user.role in ["admin", "manager", "system"]

  command create() {
    emit SelOnboardingTrainingQuestionDefinitionCreated
  }

  relationship belongsTo question: TrainingQuestion with questionId
  relationship belongsTo module: TrainingModule with moduleId

  store in memory
}

saga InstallSelOnboardingTraining {
  step moduleDefinition {
    command: SelOnboardingTrainingModuleDefinition.create
  }

  step question01 {
    command: SelOnboardingTrainingQuestion01Definition.create
  }

  step question02 {
    command: SelOnboardingTrainingQuestion02Definition.create
  }

  step question03 {
    command: SelOnboardingTrainingQuestion03Definition.create
  }

  step question04 {
    command: SelOnboardingTrainingQuestion04Definition.create
  }

  step question05 {
    command: SelOnboardingTrainingQuestion05Definition.create
  }

  step question06 {
    command: SelOnboardingTrainingQuestion06Definition.create
  }

  step question07 {
    command: SelOnboardingTrainingQuestion07Definition.create
  }

  step question08 {
    command: SelOnboardingTrainingQuestion08Definition.create
  }

  step question09 {
    command: SelOnboardingTrainingQuestion09Definition.create
  }

  step question10 {
    command: SelOnboardingTrainingQuestion10Definition.create
  }

  on_failure: "abort"
}

on SelOnboardingTrainingDefinitionCreated run TrainingModule.create
  resolve payload.result.moduleId
  params {
    id: payload.result.moduleId
    code: payload.result.code
    title: payload.result.title
    description: payload.result.description
    contentUrl: payload.result.contentUrl
    contentType: payload.result.contentType
    durationMinutes: payload.result.durationMinutes
    category: payload.result.category
    isRequired: payload.result.isRequired
    passThresholdPercent: payload.result.passThresholdPercent
    maxAttempts: payload.result.maxAttempts
    requiredRole: payload.result.requiredRole
    createdBy: "system"
    publishImmediately: true
  }

on SelOnboardingTrainingQuestionDefinitionCreated run TrainingQuestion.create
  resolve payload.result.questionId
  params {
    id: payload.result.questionId
    moduleId: payload.result.moduleId
    code: payload.result.code
    sectionTitle: payload.result.sectionTitle
    displayOrder: payload.result.displayOrder
    prompt: payload.result.prompt
    optionA: payload.result.optionA
    optionB: payload.result.optionB
    optionC: payload.result.optionC
    optionD: payload.result.optionD
    correctOptionKey: payload.result.correctOptionKey
    explanation: payload.result.explanation
    whyItMatters: payload.result.whyItMatters
  }

on StaffMemberCreated run TrainingAssignment.create
  resolve uuid()
  params {
    id: uuid()
    moduleId: "training-module-sel-event-staff-onboarding"
    moduleCode: "sel_event_staff_onboarding"
    moduleTitle: "SEL Event Staff — Onboarding Training"
    staffMemberId: payload.staffMemberId
    staffRole: payload.role
    passThresholdPercent: 80
    maxAttempts: 3
    firstShiftAt: payload.firstShiftAt
    dueAt: payload.dueAt
    dueDateReviewNeeded: true
  }

on StaffMemberFirstShiftScheduled run TrainingAssignment.applyFirstShiftDueDate
  resolve payload.staffMemberId
  params {
    assignmentId: payload.assignmentId
    moduleId: "training-module-sel-event-staff-onboarding"
    staffMemberId: payload.staffMemberId
    firstShiftAt: payload.firstShiftAt
    dueAt: payload.dueAt
  }