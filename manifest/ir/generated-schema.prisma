model ManifestCommandTelemetry {
  tenantId         String   @map("tenant_id") @db.Uuid
  id               String   @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  commandName      String   @map("command_name")
  entityName       String   @map("entity_name")
  instanceId       String?  @map("instance_id") @db.Uuid
  status           String
  errorMessage     String?  @map("error_message")
  errorCode        String?  @map("error_code")
  durationMs       Int?     @map("duration_ms")
  guardEvalMs      Int?     @map("guard_eval_ms")
  actionExecMs     Int?     @map("action_exec_ms")
  guardsEvaluated  Int?     @default(0) @map("guards_evaluated")
  guardsPassed     Int?     @default(0) @map("guards_passed")
  guardsFailed     Int?     @default(0) @map("guards_failed")
  failedGuards     Json?    @map("failed_guards")
  idempotencyKey   String?  @map("idempotency_key")
  wasIdempotentHit Boolean  @default(false) @map("was_idempotent_hit")
  eventsEmitted    Int?     @default(0) @map("events_emitted")
  performedBy      String?  @map("performed_by") @db.Uuid
  correlationId    String?  @map("correlation_id")
  causationId      String?  @map("causation_id")
  requestId        String?  @map("request_id")
  ipAddress        String?  @map("ip_address")
  executedAt       DateTime @default(now()) @map("executed_at") @db.Timestamptz(6)

  @@id([tenantId, id])
  @@index([tenantId, commandName, executedAt])
  @@index([tenantId, entityName, executedAt])
  @@index([tenantId, status, executedAt])
  @@index([tenantId, performedBy, executedAt])
  @@index([tenantId, correlationId])
  @@index([executedAt])
  @@map("manifest_command_telemetry")
  @@schema("tenant_admin")
}

model RateLimitUsage {
  tenantId        String   @map("tenant_id") @db.Uuid
  id              String   @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  endpoint        String
  method          String
  bucketStart     DateTime @map("bucket_start") @db.Timestamptz(6)
  requestCount    Int      @default(0) @map("request_count")
  blockedCount    Int      @default(0) @map("blocked_count")
  avgResponseTime Int?     @map("avg_response_time")
  maxResponseTime Int?     @map("max_response_time")
  userHashes      String[] @map("user_hashes")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@id([tenantId, id])
  @@unique([tenantId, endpoint, method, bucketStart])
  @@index([tenantId, bucketStart])
  @@index([tenantId, endpoint])
  @@map("rate_limit_usage")
  @@schema("tenant_admin")
}

model RateLimitEvent {
  tenantId         String   @map("tenant_id") @db.Uuid
  id               String   @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  endpoint         String
  method           String
  allowed          Boolean
  windowStart      DateTime @map("window_start") @db.Timestamptz(6)
  windowEnd        DateTime @map("window_end") @db.Timestamptz(6)
  requestsInWindow Int      @map("requests_in_window")
  limit            Int
  userId           String?  @map("user_id") @db.Uuid
  userAgent        String?  @map("user_agent")
  ipHash           String?  @map("ip_hash")
  responseTime     Int?     @map("response_time")
  timestamp        DateTime @default(now()) @db.Timestamptz(6)

  @@id([tenantId, id])
  @@index([tenantId, timestamp])
  @@index([tenantId, endpoint])
  @@index([tenantId, allowed])
  @@index([tenantId, userId])
  @@map("rate_limit_events")
  @@schema("tenant_admin")
}

model TaxConfiguration {
  tenant_id    String    @db.Uuid
  id           String    @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tax_type     String // federal | state | local
  jurisdiction String
  state_code   String?
  is_active    Boolean   @default(true)
  created_at   DateTime  @default(now()) @db.Timestamptz(6)
  updated_at   DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  deleted_at   DateTime? @db.Timestamptz(6)

  @@id([tenant_id, id])
  @@index([tenant_id, is_active])
  @@index([tenant_id, tax_type])
  @@map("tax_configurations")
  @@schema("tenant_staff")
}

model PayrollAuditLog {
  tenantId      String   @map("tenant_id") @db.Uuid
  id            String   @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  periodId      String   @map("period_id") @db.Uuid
  action        String
  userId        String?  @map("user_id") @db.Uuid
  inputSnapshot Json?    @map("input_snapshot") @db.JsonB
  rulesVersion  String?  @map("rules_version")
  resultSummary Json?    @map("result_summary") @db.JsonB
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Account @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@id([tenantId, id])
  @@unique([tenantId, id])
  @@index([tenantId, periodId])
  @@index([tenantId, action])
  @@index([tenantId, createdAt])
  @@map("payroll_audit_log")
  @@schema("tenant_staff")
}

model ProviderSync {
  tenantId       String    @map("tenant_id") @db.Uuid
  id             String    @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider       String // "google" | "outlook"
  providerUserId String?   @map("provider_user_id") // external account ID
  accessToken    String?   @map("access_token") @db.Text
  refreshToken   String?   @map("refresh_token") @db.Text
  tokenExpiry    DateTime? @map("token_expiry") @db.Timestamptz(6)
  calendarId     String?   @map("calendar_id") // primary calendar ID from provider
  calendarName   String?   @map("calendar_name")
  status         String    @default("disconnected") // disconnected | connected | error
  lastSyncAt     DateTime? @map("last_sync_at") @db.Timestamptz(6)
  lastSyncStatus String?   @map("last_sync_status")
  lastSyncError  String?   @map("last_sync_error") @db.Text
  syncDirection  String    @default("import") // import | export | two_way
  enabled        Boolean   @default(true)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)
  tenant         Account   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([tenantId, id])
  @@unique([tenantId, provider])
  @@index([tenantId, status])
  @@map("provider_syncs")
  @@schema("tenant_admin")
}

model AdminTaskActivity {
  tenantId  String   @map("tenant_id") @db.Uuid
  id        String   @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  taskId    String   @map("task_id") @db.Uuid
  actorId   String?  @map("actor_id") @db.Uuid
  actorName String   @map("actor_name")
  action    String
  details   Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@id([tenantId, id])
  @@index([tenantId, taskId], map: "admin_task_activity_task_idx")
  @@map("admin_task_activity")
  @@schema("tenant_admin")
}

model ExtractedDetail {
  tenantId        String    @map("tenant_id") @db.Uuid
  id              String    @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId       String    @map("session_id") @db.Uuid
  draftId         String    @map("draft_id") @db.Uuid
  fieldName       String    @map("field_name")
  rawValue        String?   @map("raw_value") @db.Text
  normalizedValue String?   @map("normalized_value")
  confidence      String    @default("medium")
  sourceQuote     String?   @map("source_quote") @db.Text
  sourceTimestamp Int?      @map("source_timestamp")
  status          String    @default("pending")
  catalogMatchType String?  @map("catalog_match_type")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@id([tenantId, id])
  @@index([tenantId, draftId], map: "extracted_details_draft_idx")
  @@index([tenantId, sessionId], map: "extracted_details_session_idx")
  @@map("extracted_details")
  @@schema("tenant_crm")
}

model ProposalAction {
  tenantId   String   @map("tenant_id") @db.Uuid
  id         String   @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  proposalId String   @map("proposal_id") @db.Uuid
  action     String
  message    String?  @db.Text
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@id([tenantId, id])
  @@index([tenantId, proposalId], map: "proposal_actions_proposal_idx")
  @@map("proposal_actions")
  @@schema("tenant_crm")
}
