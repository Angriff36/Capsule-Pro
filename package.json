{
  "name": "capsule-pro",
  "private": true,
  "dependencies": {
    "@prisma/adapter-neon": "7.8.0",
    "@prisma/client": "7.8.0",
    "ai": "^6.0.205",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "@angriff36/manifest": "2.5.1",
