{
  "name": "capsule-pro",
  "private": true,
  "dependencies": {
    "@prisma/adapter-neon": "7.8.0",
    "@prisma/client": "7.8.0",
    "ai": "^6.0.205",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "@angriff36/manifest": "3.4.23",
    "@auto-it/first-time-contributor": "^11.3.6",
    "@babel/parser": "^7.29.7",
    "@biomejs/biome": "2.5.2",
    "@clack/prompts": "^1.7.0",
    "@clerk/testing": "^2.2.2",
    "@playwright/test": "1.61.1",
    "@previewjs/config-helper-nextjs": "^1.0.29",
    "@repo/typescript-config": "workspace:*",
    "@secretlint/secretlint-rule-database-connection-string": "^13.0.2",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@turbo/gen": "2.10.3",
    "@types/node": "25.9.1",
    "baseline-browser-mapping": "^2.10.42",
    "commander": "^14.0.3",
    "cross-env": "^10.1.0",
    "dependency-cruiser": "^17.4.3",
    "fallow": "^2.96.0",
    "form-data": "^4.0.6",
    "husky": "^9.1.7",
    "inquirer": "^12.11.1",
    "knip": "^6.24.0",
    "node-fetch": "^3.3.2",
    "node-mocks-http": "^1.17.2",
    "pdfkit": "^0.18.0",
    "pg": "^8.22.0",
    "prisma": "7.8.0",
    "react": "19.2.6",
    "secretlint": "^13.0.2",
    "syncpack": "15.3.2",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "turbo": "2.10.3",
    "typescript": "^6.0.3",
    "ultracite": "7.8.4",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22 <23"
  },
  "packageManager": "pnpm@10.24.0+sha512.01ff8ae71b4419903b65c60fb2dc9d34cf8bb6e06d03bde112ef38f7a34d6904c424ba66bea5cdcf12890230bf39f9580473140ed9c946fef328b6e5238a345a",
  "scripts": {
    "analyze": "cross-env TURBO_UI=0 turbo analyze --filter=app --filter=api --filter=web",
    "boundaries": "turbo boundaries",
    "browser-tools": "pnpm dlx @modelcontextprotocol/server-playwright",
    "build": "pnpm prisma:check && turbo build --filter=./apps/app --filter=./apps/api --filter=./apps/web",
    "build:docs": "turbo build --filter=./apps/docs",
    "build:storybook": "turbo build --filter=./apps/storybook",
    "build:email": "turbo build --filter=./apps/email",
    "build:all": "pnpm prisma:check && turbo build",
    "check": "turbo typecheck --filter=./apps/app --filter=./apps/api --filter=./apps/web",
    "check:manifest": "pnpm check:manifest:structure && pnpm check:manifest:domain",
    "check:all": "turbo typecheck",
    "check:ci": "pnpm check && pnpm lint:any",
    "check:staged-write-routes": "node scripts/check-staged-write-routes.mjs",
    "manifest:build": "node manifest/scripts/build.mjs",
    "manifest:check": "node manifest/scripts/check.mjs",
    "manifest:all": "manifest compile manifest/source --merge -o manifest/ir/kitchen.ir.json && manifest generate --all manifest/ir/kitchen.ir.json",
    "manifest:update": "pnpm -r update @angriff36/manifest@latest",
    "manifest:compile": "node manifest/scripts/compile.mjs",
    "manifest:ir:embed": "node manifest/scripts/embed-ir.mjs",
    "manifest:ir:embed:check": "node manifest/scripts/check-ir-embed-drift.mjs",
    "manifest:ownership": "node manifest/scripts/emit-feature-ownership.mjs",
    "manifest:ownership:check": "node manifest/scripts/emit-feature-ownership.mjs --check",
    "manifest:ir:embed:check:self-test": "node manifest/scripts/check-ir-embed-drift.mjs --self-test",
    "manifest:generate": "node manifest/scripts/generate.mjs",
    "manifest:wiring": "node manifest/scripts/generate-wiring.mjs",
    "manifest:wiring:inspect": "node manifest/scripts/wiring-inspect.mjs",
    "manifest:wiring:remediate": "node manifest/scripts/wiring-remediate.mjs",
    "manifest:client": "node manifest/scripts/generate-capsule-client.mjs",
    "manifest:try-prisma": "node manifest/scripts/try-prisma.mjs",
    "manifest:generate-metadata": "node manifest/scripts/generate-prisma-model-metadata.mjs && node manifest/scripts/generate-entity-accessor.mjs && node manifest/scripts/build-prisma-store-options.mjs && node manifest/scripts/generate-prisma-store-projection.mjs && node manifest/scripts/generate-guard-messages.mjs",
    "manifest:guard-messages": "node manifest/scripts/generate-guard-messages.mjs",
    "manifest:field-hints": "node manifest/scripts/generate-field-hints.mjs",
    "manifest:field-hints:check": "node manifest/scripts/generate-field-hints.mjs --check",
    "manifest:check-accessor-config": "node manifest/scripts/check-accessor-config.mjs",
    "manifest:check-accessor-config:strict": "node manifest/scripts/check-accessor-config.mjs --strict",
    "manifest:schema:check": "manifest generate -p prisma --surface all -o packages/database/prisma --check manifest/ir/kitchen.ir.json",
    "manifest:openapi": "node manifest/scripts/generate-openapi.mjs",
    "manifest:openapi:check": "node manifest/scripts/check-openapi-drift.mjs",
    "manifest:openapi:check:self-test": "node manifest/scripts/check-openapi-drift.mjs --self-test",
    "manifest:doctor": "pnpm exec manifest doctor",
    "manifest:routes:ir": "tsx manifest/scripts/generate-route-manifest.ts",
    "manifest:validate": "pnpm exec manifest validate manifest/ir/kitchen.ir.json",
    "manifest:validate-ai": "pnpm exec manifest validate-ai manifest/ir/kitchen.ir.json --min-score 100",
    "manifest:verify-invariants": "node manifest/scripts/verify-invariants.mjs",
    "manifest:command-schemas": "node manifest/scripts/generate-command-param-schemas.mjs",
    "manifest:sync-artifacts": "pnpm manifest:build && pnpm manifest:client && pnpm manifest:generate-metadata && pnpm manifest:command-schemas && pnpm manifest:field-hints && pnpm manifest:registries && pnpm manifest:ownership && pnpm manifest:openapi && pnpm manifest:ir:embed",
    "manifest:ci": "pnpm manifest:verify-invariants && pnpm manifest:validate && pnpm manifest:doctor && pnpm manifest:contract:check && pnpm manifest:audit-governance:direct-writes && pnpm manifest:audit:strict && pnpm manifest:coverage:ci",
    "manifest:registries": "node manifest/scripts/emit-registries.mjs",
    "manifest:contract:check": "node manifest/scripts/audit-contract-imports.mjs",
    "manifest:audit-governance:direct-writes": "pnpm exec manifest audit-governance -r apps/api --only direct-writes --commands-registry ../../manifest/governance/commands.json --bypass-registry ../../manifest/governance/bypasses.json --strict && pnpm exec manifest audit-governance -r apps/app --only direct-writes --commands-registry ../../manifest/governance/commands.json --bypass-registry ../../manifest/governance/bypasses.json --strict",
    "manifest:audit-ir-drift": "node manifest/scripts/audit-ir-drift.mjs",
    "manifest:audit-ir-drift:strict": "node manifest/scripts/audit-ir-drift.mjs --strict",
    "bump-deps": "pnpm dlx npm-check-updates --deep -u --reject recharts && pnpm install",
    "bump-ui": "cd packages/design-system && pnpm dlx shadcn@latest add --all --overwrite",
    "clean:hard": "git clean -xdf",
    "clean:node_modules": "git clean -xdf node_modules",
    "clean:preview": "git clean -ndx",
    "ports": "pwsh -Command \"2221..2226 | ForEach-Object { $port = $_; Get-NetTCPConnection -LocalPort $port -ErrorAction SilentlyContinue | ForEach-Object { Stop-Process -Id $_.OwningProcess -Force -ErrorAction SilentlyContinue } }\"",
    "db:check": "node scripts/db-drift-check.mjs",
    "db:validate-migrations": "node scripts/validate-migration-table-schemas.mjs",
    "db:validate-migrations:test": "node --test scripts/__tests__/validate-migration-table-schemas.test.mjs",
    "db:validate-generated-migration": "node scripts/validate-generated-migration.mjs",
    "db:validate-generated-migration:test": "node --test scripts/__tests__/validate-generated-migration.test.mjs",
    "db:deploy": "pnpm --filter @repo/database exec prisma migrate deploy",
    "db:dev": "pnpm --filter @repo/database exec prisma migrate dev",
    "db:push": "echo \"❌ Disabled. Use pnpm migrate (dev) or pnpm migrate:deploy (CI/prod).\" && exit 1",
    "dev": "turbo dev --parallel",
    "dev:app": "turbo run dev --filter=./apps/app",
    "dev:api": "turbo run dev --filter=./apps/api",
    "dev:web": "turbo run dev --filter=./apps/api --filter=./apps/app --parallel --continue",
    "dev:apps": "turbo run dev --filter=./apps/api --filter=./apps/app --filter=./apps/mobile --parallel --continue",
    "dev:mobile": "scripts\\mobile-dev.cmd",
    "dev:mobile:stack": "scripts\\dev-mobile-stack.cmd",
    "dev:check": "node scripts/dev.mjs",
    "docs:list": "tsx ./tools/scripts/docs-list.ts",
    "logging:sync": "tsx scripts/logging/sync-all.ts",
    "logging:sentry": "tsx scripts/logging/sync-sentry.ts",
    "logging:todos": "tsx scripts/logging/scan-todos.ts",
    "logging:arch": "tsx scripts/logging/analyze-architecture.ts",
    "lint": "pnpm exec ultracite check",
    "lint:any": "node scripts/lint-explicit-any.mjs",
    "lint:fix": "pnpm exec ultracite fix",
    "migrate": "pnpm db:validate-migrations && pnpm db:check && pnpm prisma:check && pnpm db:dev",
    "migrate:deploy": "pnpm db:validate-migrations && pnpm prisma:check && pnpm db:deploy",
    "migrate:resolve": "pnpm --filter @repo/database exec prisma migrate resolve",
    "migrate:baseline": "node scripts/migrate-baseline.mjs",
    "migrate:status": "pnpm --filter @repo/database exec prisma migrate status",
    "predev": "pnpm db:check",
    "prepare": "husky",
    "prisma:format": "pnpm --filter @repo/database exec prisma format",
    "prisma:check": "pnpm exec prisma generate --schema=./packages/database/prisma/schema",
    "secrets:scan": "secretlint \"**/*\"",
    "security:audit-baseline": "node scripts/security/audit-baseline.mjs",
    "security:audit-baseline:save": "node scripts/security/audit-baseline.mjs --save-baseline",
    "test": "turbo test --filter=./apps/app --filter=./apps/api",
    "test:all": "turbo test",
    "test:e2e": "playwright test",
    "test:kitchen": "playwright test e2e/kitchen-workflow.spec.ts",
    "translate": "turbo translate",
    "audit:theatre": "node scripts/audit-implementation-theatre.mjs",
    "governance:verify-routes": "pnpm exec tsx scripts/verify-governance-route-findings.mjs",
    "vercel:bisect": "node scripts/vercel-bisect.mjs",
    "e2e:lint": "bash e2e/scripts/lint-workflow-specs.sh",
    "install:infisical": "infisical run --env=dev --path=/apps/capsule-pro/app --project-config-dir=. -- pnpm install",
    "dev:web:infisical": "turbo run dev:infisical --filter=./apps/api --filter=./apps/app --parallel --continue",
    "dev:web:infisical:manifest-log": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-web-infisical-manifest-log.ps1",
    "build:infisical": "turbo run build:infisical",
    "knip": "knip --config knip.ts",
    "manifest:audit-reaction-payloads": "node manifest/scripts/check-reaction-payloads.mjs --strict",
    "manifest:audit-schema-drift": "node manifest/scripts/audit-schema-drift.mjs",
    "manifest:audit-schema-drift:strict": "node manifest/scripts/audit-schema-drift.mjs --strict",
    "manifest:audit-parent-context": "node manifest/scripts/audit-parent-context.mjs",
    "manifest:audit-parent-context:strict": "node manifest/scripts/audit-parent-context.mjs --strict",
    "manifest:audit-command-param-types": "node manifest/scripts/audit-command-param-types.mjs",
    "manifest:audit-command-param-types:strict": "node manifest/scripts/audit-command-param-types.mjs --strict",
    "manifest:audit-command-param-types:baseline": "node manifest/scripts/audit-command-param-types.mjs --update-baseline",
    "manifest:audit-command-param-types:self-test": "node manifest/scripts/audit-command-param-types.mjs --self-test",
    "manifest:audit-dead-commands": "node manifest/scripts/audit-dead-commands.mjs",
    "manifest:audit-dead-commands:strict": "node manifest/scripts/audit-dead-commands.mjs --strict",
    "manifest:lint-schema": "node manifest/scripts/lint-schema.mjs",
    "manifest:lint-schema:strict": "node manifest/scripts/lint-schema.mjs --strict",
    "manifest:lint-schema:self-test": "node manifest/scripts/lint-schema.mjs --self-test",
    "manifest:mcp": "manifest-mcp",
    "scripts:audit": "node tools/audit-package-scripts.mjs",
    "check:scripts": "node tools/audit-package-scripts.mjs",
    "check:manifest:structure": "node tools/manifest-structure-audit.mjs",
    "check:manifest:domain": "node tools/manifest-domain-drift-audit.mjs",
    "manifest:audit": "pnpm manifest:audit-schema-drift && pnpm manifest:audit-parent-context && pnpm manifest:audit-reaction-payloads",
    "manifest:audit:strict": "pnpm manifest:check-accessor-config:strict && pnpm manifest:audit-schema-drift:strict && pnpm manifest:audit-parent-context:strict && pnpm manifest:audit-reaction-payloads && pnpm manifest:audit-command-param-types:strict",
    "manifest:coverage": "manifest coverage --ir manifest/ir/kitchen.ir.json --root . --format text",
    "manifest:coverage:json": "manifest coverage --ir manifest/ir/kitchen.ir.json --root . --format json",
    "manifest:coverage:ci": "manifest coverage --ir manifest/ir/kitchen.ir.json --root . --format text --min-coverage 10 --strict",
    "manifest:fmt": "manifest fmt manifest/source -g \"**/*.manifest\" --write",
    "manifest:fmt:check": "manifest fmt manifest/source -g \"**/*.manifest\" --check",
    "cleaner": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cleaner.ps1"
  },
  "type": "module"
}
