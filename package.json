{
  "name": "capsule-pro",
  "private": true,
  "dependencies": {
    "@angriff36/manifest": "2.2.0",
    "@prisma/adapter-neon": "7.8.0",
    "@prisma/client": "7.8.0",
    "ai": "^6.0.191",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "@auto-it/first-time-contributor": "^11.3.6",
    "@babel/parser": "^7.29.7",
    "@biomejs/biome": "2.4.15",
    "@clack/prompts": "^1.4.0",
    "@clerk/testing": "^2.0.33",
    "@playwright/test": "1.60.0",
    "@repo/typescript-config": "workspace:*",
    "@secretlint/secretlint-rule-database-connection-string": "^13.0.2",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "@turbo/gen": "2.9.15",
    "@types/node": "25.9.1",
    "baseline-browser-mapping": "^2.10.32",
    "commander": "^14.0.3",
    "cross-env": "^10.1.0",
    "fallow": "^2.86.0",
    "husky": "^9.1.7",
    "inquirer": "^12.11.1",
    "knip": "^6.14.2",
    "node-mocks-http": "^1.17.2",
    "pg": "^8.21.0",
    "prisma": "7.8.0",
    "secretlint": "^13.0.2",
    "syncpack": "15.3.1",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "turbo": "2.9.15",
    "typescript": "^6.0.3",
    "ultracite": "7.8.0",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=22 <23"
  },
  "packageManager": "pnpm@10.24.0+sha512.01ff8ae71b4419903b65c60fb2dc9d34cf8bb6e06d03bde112ef38f7a34d6904c424ba66bea5cdcf12890230bf39f9580473140ed9c946fef328b6e5238a345a",
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "@types/react": ">=19",
        "@types/react-dom": ">=19",
        "ai": ">=6",
        "react": ">=19",
        "react-dom": ">=19",
        "next": ">=15",
        "zod": ">=4"
      }
    },
    "overrides": {
      "parse5": "^7.2.1",
      "@babel/core": "7.29.7",
      "next": "16.2.6",
      "react": "19.2.6",
      "react-dom": "19.2.6",
      "@types/react": "19.2.15",
      "@types/react-dom": "19.2.3",
      "mobile>react": "19.1.0",
      "mobile>@types/react": "~19.1.10",
      "prisma": "7.3.0",
      "@prisma/client": "7.3.0",
      "@prisma/adapter-neon": "7.3.0",
      "baseline-browser-mapping": "^2.9.19"
    },
    "ignoredBuiltDependencies": [
      "@clerk/shared",
      "bufferutil",
      "core-js",
      "core-js-pure",
      "protobufjs"
    ],
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "@sentry/cli",
      "esbuild",
      "prisma",
      "sharp"
    ],
    "patchedDependencies": {
      "ultracite": "patches/ultracite.patch"
    }
  },
  "scripts": {
    "analyze": "cross-env TURBO_UI=0 turbo analyze --filter=app --filter=api --filter=web",
    "boundaries": "turbo boundaries",
    "browser-tools": "pnpm dlx @modelcontextprotocol/server-playwright",
    "build": "pnpm prisma:check && turbo build --filter=./apps/app --filter=./apps/api --filter=./apps/web",
    "build:docs": "turbo build --filter=./apps/docs",
    "build:storybook": "turbo build --filter=./apps/storybook",
    "build:email": "turbo build --filter=./apps/email",
    "build:all": "pnpm prisma:check && turbo build",
    "check": "turbo typecheck --filter=./apps/app --filter=./apps/api --filter=./apps/web",
    "check:manifest": "pnpm check:manifest:structure && pnpm check:manifest:domain",
    "check:all": "turbo typecheck",
    "check:ci": "pnpm check && pnpm lint:any",
    "check:staged-write-routes": "node scripts/check-staged-write-routes.mjs",
    "manifest:build": "node manifest/scripts/build.mjs",
    "manifest:check": "node manifest/scripts/check.mjs",
    "manifest:compile": "node manifest/scripts/compile.mjs",
    "manifest:generate": "node manifest/scripts/generate.mjs",
    "manifest:client": "node manifest/scripts/generate-capsule-client.mjs",
    "manifest:try-prisma": "node manifest/scripts/try-prisma.mjs",
    "manifest:derive-options": "node manifest/scripts/derive-prisma-options.mjs",
    "manifest:generate-zod": "node manifest/scripts/generate-zod-schemas.mjs",
    "manifest:generate-schema": "node manifest/scripts/generate-full-schema.mjs",
    "manifest:schema:full": "node manifest/scripts/derive-prisma-options.mjs && node manifest/scripts/generate-full-schema.mjs",
    "manifest:doctor": "pnpm exec manifest doctor",
    "manifest:inspect": "pnpm exec manifest inspect entity",
    "manifest:diff": "pnpm exec manifest diff source-vs-ir",
    "manifest:duplicates": "pnpm exec manifest duplicates",
    "manifest:runtime-check": "pnpm exec manifest runtime-check",
    "manifest:cache-status": "pnpm exec manifest cache-status",
    "manifest:route-audit": "pnpm exec manifest audit-routes --root apps/api --commands-manifest manifest/runtime/commands.registry.json --exemptions manifest/governance/audit-routes-exemptions.json",
    "manifest:routes:ir": "tsx manifest/scripts/generate-route-manifest.ts",
    "manifest:validate": "pnpm exec manifest validate manifest/ir/kitchen.ir.json",
    "manifest:validate-ai": "pnpm exec manifest validate-ai manifest/ir/kitchen.ir.json --min-score 80",
    "manifest:registries": "node manifest/scripts/emit-registries.mjs",
    "manifest:audit-ir-drift": "node manifest/scripts/audit-ir-drift.mjs",
    "manifest:audit-ir-drift:strict": "node manifest/scripts/audit-ir-drift.mjs --strict",
    "manifest:audit-direct-writes": "node manifest/scripts/audit-direct-writes.mjs",
    "manifest:audit-direct-writes:strict": "node manifest/scripts/audit-direct-writes.mjs --strict",
    "manifest:audit-direct-writes:baseline": "node manifest/scripts/audit-direct-writes-baseline.mjs",
    "bump-deps": "pnpm dlx npm-check-updates --deep -u --reject recharts && pnpm install",
    "bump-ui": "cd packages/design-system && pnpm dlx shadcn@latest add --all --overwrite",
    "clean:hard": "git clean -xdf",
    "clean:node_modules": "git clean -xdf node_modules",
    "clean:preview": "git clean -ndx",
    "ports": "pwsh -Command \"2221..2226 | ForEach-Object { $port = $_; Get-NetTCPConnection -LocalPort $port -ErrorAction SilentlyContinue | ForEach-Object { Stop-Process -Id $_.OwningProcess -Force -ErrorAction SilentlyContinue } }\"",
    "db:check": "node scripts/db-drift-check.mjs",
    "db:validate-migrations": "node scripts/validate-migration-table-schemas.mjs",
    "db:validate-migrations:test": "node --test scripts/__tests__/validate-migration-table-schemas.test.mjs",
    "db:neon-shadow": "node scripts/neon-shadow-database-setup.mjs",
    "db:neon-backup-schema": "node scripts/neon-schema-backup-pgdump.mjs",
    "db:neon-audit": "node scripts/neon-audit-readonly.mjs",
    "db:neon-backup-and-audit": "node scripts/neon-schema-backup-pgdump.mjs && node scripts/neon-audit-readonly.mjs",
    "db:deploy": "pnpm --filter @repo/database exec prisma migrate deploy",
    "db:dev": "pnpm --filter @repo/database exec prisma migrate dev",
    "db:push": "echo \"❌ Disabled. Use pnpm migrate (dev) or pnpm migrate:deploy (CI/prod).\" && exit 1",
    "db:repair": "node scripts/db-drift-repair.mjs",
    "dev": "turbo dev --parallel",
    "dev:app": "turbo run dev --filter=./apps/app",
    "dev:api": "turbo run dev --filter=./apps/api",
    "dev:web": "turbo run dev --filter=./apps/api --filter=./apps/app --parallel --continue",
    "dev:apps": "turbo run dev --filter=./apps/api --filter=./apps/app --filter=./apps/mobile --parallel --continue",
    "dev:mobile": "scripts\\mobile-dev.cmd",
    "dev:mobile:stack": "scripts\\dev-mobile-stack.cmd",
    "dev:check": "node scripts/dev.mjs",
    "docs:list": "tsx ./tools/scripts/docs-list.ts",
    "logging:sync": "tsx scripts/logging/sync-all.ts",
    "logging:sentry": "tsx scripts/logging/sync-sentry.ts",
    "logging:todos": "tsx scripts/logging/scan-todos.ts",
    "logging:arch": "tsx scripts/logging/analyze-architecture.ts",
    "lint": "pnpm exec ultracite check",
    "lint:any": "node scripts/lint-explicit-any.mjs",
    "lint:fix": "pnpm exec ultracite fix",
    "migrate": "pnpm db:validate-migrations && pnpm db:check && pnpm prisma:format && pnpm prisma:check && pnpm db:dev",
    "migrate:deploy": "pnpm db:validate-migrations && pnpm prisma:check && pnpm db:deploy",
    "migrate:resolve": "pnpm --filter @repo/database exec prisma migrate resolve",
    "migrate:baseline": "node scripts/migrate-baseline.mjs",
    "migrate:status": "pnpm --filter @repo/database exec prisma migrate status",
    "predev": "pnpm db:check",
    "prepare": "husky",
    "prisma:format": "pnpm --filter @repo/database exec prisma format",
    "prisma:check": "pnpm exec prisma generate --schema=./packages/database/prisma/schema.prisma",
    "secrets:scan": "secretlint \"**/*\"",
    "security:audit-baseline": "node scripts/security/audit-baseline.mjs",
    "security:audit-baseline:save": "node scripts/security/audit-baseline.mjs --save-baseline",
    "test": "turbo test --filter=./apps/app --filter=./apps/api",
    "test:all": "turbo test",
    "test:e2e": "playwright test",
    "test:kitchen": "playwright test e2e/kitchen-workflow.spec.ts",
    "translate": "turbo translate",
    "audit:theatre": "node scripts/audit-implementation-theatre.mjs",
    "governance:verify-routes": "pnpm exec tsx scripts/verify-governance-route-findings.mjs",
    "vercel:bisect": "node scripts/vercel-bisect.mjs",
    "e2e:lint": "bash e2e/scripts/lint-workflow-specs.sh",
    "install:infisical": "infisical run --env=dev --path=/apps/capsule-pro/app --project-config-dir=. -- pnpm install",
    "dev:web:infisical": "turbo run dev:infisical --filter=./apps/api --filter=./apps/app --parallel --continue",
    "dev:web:infisical:manifest-log": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-web-infisical-manifest-log.ps1",
    "build:infisical": "turbo run build:infisical",
    "knip": "knip",
    "manifest:audit-schema-drift": "node manifest/scripts/audit-schema-drift.mjs",
    "manifest:audit-schema-drift:strict": "node manifest/scripts/audit-schema-drift.mjs --strict",
    "manifest:audit-route-drift": "node manifest/scripts/audit-route-drift.mjs",
    "manifest:audit-route-drift:strict": "node manifest/scripts/audit-route-drift.mjs --strict",
    "manifest:audit-parent-context": "node manifest/scripts/audit-parent-context.mjs",
    "manifest:audit-parent-context:strict": "node manifest/scripts/audit-parent-context.mjs --strict",
    "manifest:mcp": "manifest-mcp",
    "manifest:governance:enforce-surface": "pnpm exec manifest enforce-surface",
    "manifest:governance:integration-check": "pnpm exec manifest integration-check",
    "manifest:governance:audit": "pnpm exec manifest audit-governance",
    "manifest:governance:audit-bypasses": "pnpm exec manifest audit-bypasses",
    "manifest:governance:scan": "pnpm exec manifest scan",
    "manifest:governance:doctor": "pnpm exec manifest doctor --governance",
    "manifest:governance:audit-routes": "pnpm exec manifest audit-routes",
    "manifest:preflight": "pnpm exec manifest preflight",
    "manifest:coverage": "pnpm exec manifest coverage",
    "manifest:routes": "pnpm exec manifest routes",
    "manifest:fmt": "pnpm exec manifest fmt",
    "scripts:audit": "node tools/audit-package-scripts.mjs",
    "check:scripts": "node tools/audit-package-scripts.mjs",
    "check:manifest:structure": "node tools/manifest-structure-audit.mjs",
    "check:manifest:domain": "node tools/manifest-domain-drift-audit.mjs"
  },
  "type": "module"
}
