# Manifest pre-commit hook (U16/U18): when .manifest source is staged, enforce
# validation before the commit lands. No-op when no .manifest files are staged
# so non-manifest commits stay fast. (Uses the CLI directly — the consolidated
# pnpm surface is manifest:build / manifest:ci / manifest:update only.)
staged_manifests=$(git diff --cached --name-only --diff-filter=ACM -- '*.manifest')

if [ -n "$staged_manifests" ]; then
  echo "manifest pre-commit: validating IR after staged .manifest changes…"
  pnpm exec manifest validate manifest/ir/kitchen.ir.json || {
    echo "✗ manifest validation failed."
    exit 1
  }
fi

# Secret scan on staged files only (fast path; the full-tree scan runs in CI
# via security.yml). A key must be caught BEFORE it reaches the remote.
staged_files=$(git diff --cached --name-only --diff-filter=ACM)
if [ -n "$staged_files" ]; then
  printf '%s\n' "$staged_files" | tr '\n' '\0' | xargs -0 pnpm exec secretlint || {
    echo "✗ secretlint found potential secrets in staged files. Commit blocked."
    exit 1
  }
fi
