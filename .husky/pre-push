#!/usr/bin/env sh
# Pre-push: fast checks before code leaves the machine.
# Heavy CI gates run on PR; this catches obvious breakage early.

echo "[pre-push] Running fast typecheck..."

# Typecheck the three main apps (fast, covers most regressions)
pnpm turbo typecheck --filter=./apps/app --filter=./apps/api --filter=./apps/web || {
  echo "[pre-push] ❌ Typecheck failed. Fix errors and try again."
  exit 1
}

echo "[pre-push] ✅ Typecheck passed."
