# =============================================================================
# apps/app — Main Web Application
# =============================================================================
# Extends packages: auth, analytics, collaboration, database, email,
#                   feature-flags, notifications, observability, security,
#                   webhooks, next-config (see each package's .env.example)
# Set SKIP_ENV_VALIDATION=1 to bypass validation during CI/build.

# ------------------------------------------------------------------
# App-specific (not owned by any shared package)
# ------------------------------------------------------------------
ABLY_API_KEY="..."
# NEXT_PUBLIC_ABLY_ENABLED="true"
# COMMAND_BOARD_AI_MODEL="gpt-4o-mini"

# ------------------------------------------------------------------
# Optional: Plasmic Visual Builder
# ------------------------------------------------------------------
# PLASMIC_PROJECT_ID=
# PLASMIC_API_TOKEN=

# ------------------------------------------------------------------
# Optional: Additional AI providers
# ------------------------------------------------------------------
