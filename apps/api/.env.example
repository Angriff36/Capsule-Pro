# =============================================================================
# apps/api — Backend API
# =============================================================================
# Extends packages: auth, analytics, database, email, observability, payments,
#                   next-config (see each package's .env.example for their vars)
# Set SKIP_ENV_VALIDATION=1 to bypass validation during CI/build.

# ------------------------------------------------------------------
# API-specific (defined in apps/api/env.ts)
# ------------------------------------------------------------------
ABLY_API_KEY="..."
# ABLY_AUTH_CORS_ORIGINS="http://localhost:2221,http://localhost:2222"
OUTBOX_PUBLISH_TOKEN="..."
# CRON_SECRET="..."

# ------------------------------------------------------------------
# External Calendar Sync (OAuth 2.0)
# ------------------------------------------------------------------
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# OAUTH_REDIRECT_URI="http://localhost:3000"

# ------------------------------------------------------------------
# Misc (read via process.env, not in Zod schema)
# ------------------------------------------------------------------
# RESEND_WEBHOOK_SECRET="whsec_..."   — Resend webhook handler
# CAPSULE_SENTRY_CANARY_SECRET="..."  — /api/health/sentry-canary
# MINIMAX_API_KEY="..."               — AI provider (optional)
# SUPERMEMORY_API_KEY="..."           — AI provider (optional)
# AI_GATEWAY_API_KEY="..."            — AI provider (optional)
