{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd ../.. && pnpm turbo build --filter=api",
  "installCommand": "corepack enable && corepack prepare pnpm@10.24.0 --activate && bash ../../scripts/ensure-github-packages-npmrc.sh && pnpm install",
  "ignoreCommand": "bash -c 'echo \"Git-triggered builds skipped (exit 0=ignore); use GitHub Actions Deploy workflow or vercel CLI\" >&2; exit 0'",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "functions": {
    "app/api/**/*.ts": {
      "regions": ["iad1"]
    },
    "app/cron/**/*.ts": {
      "regions": ["iad1"]
    }
  },
  "crons": [
    {
      "path": "/api/sentry-fixer/process",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/webhook-retry",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/inventory-audit",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/contract-expiration-alerts",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/email-reminders",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/idempotency-cleanup",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/integration-auto-sync",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/outbox/publish",
      "schedule": "* * * * *"
    }
  ]
}
