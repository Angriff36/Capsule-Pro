{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd ../.. && pnpm turbo build --filter=api",
  "installCommand": "corepack enable && corepack prepare pnpm@10.24.0 --activate && pnpm install",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "functions": {
    "app/api/**/*.ts": {
      "regions": ["iad1"]
    },
    "app/cron/**/*.ts": {
      "regions": ["iad1"]
    }
  },
  "crons": [
    {
      "path": "/api/sentry-fixer/process",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/webhook-retry",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/inventory-audit",
      "schedule": "0 6 * * *"
    }
  ]
}
