# Sentry source map upload ignore patterns
# This prevents uploading source maps for files we don't need

# Node modules (except our workspace packages)
node_modules/**
!node_modules/@repo/**
!node_modules/@manifest/**

# Next.js framework internals - these have their own source maps
.next/static/chunks/framework-*.js
.next/static/chunks/framework-*.js.map
.next/static/chunks/main-*.js
.next/static/chunks/main-*.js.map
.next/static/chunks/webpack-*.js
.next/static/chunks/webpack-*.js.map
.next/static/chunks/polyfills-*.js
.next/static/chunks/polyfills-*.js.map

# Build artifacts we don't need
.next/cache/**
.next/server/chunks/**
.next/static/media/**

# Test files
**/*.test.js
**/*.test.ts
**/*.spec.js
**/*.spec.ts

# Config files
*.config.js
*.config.ts
