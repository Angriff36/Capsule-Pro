link-workspace-packages=true
# Wrong Node version must fail loudly (engines: >=22 <23, .nvmrc 22.18.0)
engine-strict=true
# TODO(de-hoist): remove shamefully-hoist + restore strict-peer-dependencies on a
# dedicated branch — disruptive, do last, alone. See .artifacts/repo-checks-map-ideal.html
shamefully-hoist=true
strict-peer-dependencies=false
fetch-timeout=60000
fetch-retries=5
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000