# Used by Prisma CLI when run from packages/database (migrate / generate).
# Neon hosts: ep-square-dust = dev, ep-divine-math = prod (never point local dev at prod).
DATABASE_URL=""

# Optional Neon read-replica URL for analytics/reporting queries.
# When unset, analytics routes fall back to DATABASE_URL (primary).
#ANALYTICS_DATABASE_URL="postgresql://..."

# Prisma Migrate shadow DB only — local file packages/database/.env.local (gitignored).
# Create the Neon DB + URL: NEON_PROJECT_ID=... pnpm db:neon-shadow -- --write
# Do NOT set SHADOW_DATABASE_URL on Vercel production; app/api build and prisma generate do not need it.
#SHADOW_DATABASE_URL="postgresql://..."