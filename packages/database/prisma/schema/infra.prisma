model ReactionLog {
  tenantId      String   @map("tenant_id") @db.Uuid
  id            String   @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// Triggering command's entity (e.g. "Event"). Null when the IR omits it.
  entity        String?
  /// Triggering command name (e.g. "create", "applyPayment").
  command       String
  /// "success" | "failed" — failed captures silent no-ops / guard failures.
  status        String
  /// Names of the semantic events this command emitted.
  emittedEvents String[] @map("emitted_events")
  /// IR reactions ("Entity.command") triggered by the emitted events.
  reactions     String[]
  /// Guard/runtime failure detail when status = "failed".
  errorMessage  String?  @map("error_message")
  /// Shape of the command input (keys only — no values, to avoid leaking PII).
  payloadKeys   String[] @map("payload_keys")
  /// Wall-clock execution time of the command in milliseconds.
  durationMs    Int?     @map("duration_ms")
  /// Reserved for future retry instrumentation (runtime is fire-once today).
  retryCount    Int      @default(0) @map("retry_count")
  /// Correlation id grouping a whole propagation cascade.
  correlationId String?  @map("correlation_id")
  /// Causation id linking this command to the one that triggered it.
  causationId   String?  @map("causation_id")
  /// Origin surface, when supplied (route/job/cli/...).
  source        String?
  /// Acting user id.
  actorId       String?  @map("actor_id")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@id([tenantId, id])
  @@index([tenantId, createdAt])
  @@index([tenantId, status, createdAt])
  @@index([tenantId, correlationId])
  @@index([tenantId, entity, command, createdAt])
  @@map("reaction_logs")
  @@schema("tenant_admin")
}

