model WasteEntry {
  id String
  tenantId String @map("tenant_id")
  deletedAt DateTime? @map("deleted_at")
  inventoryItemId String? @map("inventory_item_id") @default("")
  reasonId Int? @map("reason_id") @default(0)
  quantity Decimal? @db.Decimal(12, 2) @default(0)
  unitId Int? @map("unit_id") @default(0)
  locationId String? @map("location_id") @default("")
  eventId String? @map("event_id") @default("")
  loggedBy String? @map("logged_by") @default("")
  loggedAt DateTime? @map("logged_at")
  approvedBy String? @map("approved_by") @default("")
  approvedAt DateTime? @map("approved_at")
  status String? @default("logged")
  unitCost Decimal? @map("unit_cost") @db.Decimal(12, 2) @default(0)
  totalCost Decimal? @map("total_cost") @db.Decimal(12, 2) @default(0)
  notes String? @default("")
  createdAt DateTime? @map("created_at") @default(now())
  updatedAt DateTime? @map("updated_at") @updatedAt

  item InventoryItem? @relation(fields: [tenantId, inventoryItemId], references: [tenantId, id])
  event Event? @relation(fields: [tenantId, eventId], references: [tenantId, id])
  location Facility? @relation(fields: [tenantId, locationId], references: [tenantId, id])

  @@map("waste_entries")
  @@id([tenantId, id])
  @@schema("tenant_kitchen")
}

