model VersionedEntity {
  id String
  tenantId String @map("tenant_id")
  entityType String @map("entity_type")
  entityId String @map("entity_id")
  entityName String @map("entity_name")
  isLocked Boolean? @map("is_locked") @default(false)
  currentVersionId String? @map("current_version_id") @default("")
  createdAt DateTime? @map("created_at") @default(now())
  updatedAt DateTime? @map("updated_at") @updatedAt

  currentVersion EntityVersion? @relation("VersionedEntity_currentVersion", fields: [currentVersionId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  entityVersions EntityVersion[] @relation("EntityVersion_versionedEntity")

  @@map("versioned_entities")
  @@id([tenantId, id])
  @@unique([id])
  @@schema("public")
}

