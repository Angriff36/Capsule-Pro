model Venue {
  id String
  tenantId String @map("tenant_id")
  deletedAt DateTime? @map("deleted_at")
  name String @default("")
  venueType String? @map("venue_type") @default("other")
  addressLine1 String? @map("address_line1") @default("")
  addressLine2 String? @map("address_line2") @default("")
  city String? @default("")
  stateProvince String? @map("state_province") @default("")
  postalCode String? @map("postal_code") @default("")
  countryCode String? @map("country_code") @default("")
  capacity Int? @default(0)
  contactName String? @map("contact_name") @default("")
  contactPhone String? @map("contact_phone") @default("")
  contactEmail String? @map("contact_email") @default("")
  accessNotes String? @map("access_notes") @default("")
  cateringNotes String? @map("catering_notes") @default("")
  layoutImageUrl String? @map("layout_image_url") @default("")
  tags String[]
  isActive Boolean? @map("is_active") @default(true)
  createdAt DateTime? @map("created_at") @default(now())
  updatedAt DateTime? @map("updated_at") @updatedAt

  eventsVenue Event[] @relation("Event_venue")
  eventsVenueEntity Event[] @relation("Event_venueEntity")

  @@map("venues")
  @@id([tenantId, id])
  @@schema("tenant")
}

