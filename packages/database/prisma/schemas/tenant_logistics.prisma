// Route Optimization Models - Delivery/Catering Route Management

model DeliveryRoute {
  tenantId      String   @map("tenant_id") @db.Uuid
  id            String   @unique @default(dbgenerated("gen_random_uuid()")) @map("id") @db.Uuid
  routeNumber   String   @map("route_number")
  name          String
  description   String?
  status        String   @default("draft") // draft, optimized, in_progress, completed, cancelled
  eventId       String?  @map("event_id") @db.Uuid
  
  // Route timing
  scheduledDate DateTime? @map("scheduled_date") @db.Date
  startTime     DateTime? @map("start_time") @db.Timestamptz(6)
  endTime       DateTime? @map("end_time") @db.Timestamptz(6)
  
  // Optimization metadata
  totalDistance Decimal? @map("total_distance") @db.Decimal(10, 2) // in km
  totalDuration Int?     @map("total_duration") // in minutes
  optimizationScore Decimal? @map("optimization_score") @db.Decimal(5, 2)
  optimizationAlgorithm String? @map("optimization_algorithm")
  
  // Driver assignment
  driverId      String?  @map("driver_id") @db.Uuid
  vehicleId     String?  @map("vehicle_id") @db.Uuid
  
  // Tracking
  actualStartTime   DateTime? @map("actual_start_time") @db.Timestamptz(6)
  actualEndTime     DateTime? @map("actual_end_time") @db.Timestamptz(6)
  actualDistance    Decimal? @map("actual_distance") @db.Decimal(10, 2)
  
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)
  
  tenant        Account      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  stops         RouteStop[]
  
  @@id([tenantId, id])
  @@unique([tenantId, routeNumber])
  @@index([tenantId, status])
  @@index([tenantId, scheduledDate])
  @@map("delivery_routes")
  @@schema("tenant_logistics")
}

model RouteStop {
  tenantId      String   @map("tenant_id") @db.Uuid
  id            String   @unique @default(dbgenerated("gen_random_uuid()")) @map("id") @db.Uuid
  routeId       String   @map("route_id") @db.Uuid
  stopNumber    Int      @map("stop_number")
  
  // Location reference
  locationId    String?  @map("location_id") @db.Uuid
  venueId       String?  @map("venue_id") @db.Uuid
  
  // Address (can be derived from location/venue or entered manually)
  name          String
  addressLine1  String?  @map("address_line1")
  addressLine2  String?  @map("address_line2")
  city          String?
  stateProvince String?  @map("state_province")
  postalCode    String?  @map("postal_code")
  countryCode   String?  @map("country_code") @db.Char(2)
  
  // Coordinates for mapping
  latitude      Decimal? @db.Decimal(10, 8)
  longitude     Decimal? @db.Decimal(11, 8)
  
  // Stop details
  stopType      String   @default("delivery") // pickup, delivery, break
  plannedArrival DateTime? @map("planned_arrival") @db.Timestamptz(6)
  plannedDuration Int?   @map("planned_duration") // minutes at stop
  notes         String?
  
  // Optimization metadata
  distanceFromPrevious Decimal? @map("distance_from_previous") @db.Decimal(10, 2) // km
  timeFromPrevious     Int?     @map("time_from_previous") // minutes
  
  // Tracking
  status        String   @default("pending") // pending, in_transit, arrived, completed, skipped
  actualArrival DateTime? @map("actual_arrival") @db.Timestamptz(6)
  actualDeparture DateTime? @map("actual_departure") @db.Timestamptz(6)
  
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  
  route         DeliveryRoute @relation(fields: [routeId, tenantId], references: [id, tenantId], onDelete: Cascade)
  
  @@id([tenantId, id])
  @@unique([routeId, stopNumber])
  @@index([routeId, status])
  @@map("route_stops")
  @@schema("tenant_logistics")
}
