{
  "name": "@repo/database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./index.ts",
      "default": "./index.ts"
    },
    "./standalone": {
      "import": "./standalone.ts",
      "default": "./standalone.ts"
    },
    "./keys": {
      "import": "./keys.ts",
      "default": "./keys.ts"
    },
    "./generated/client": {
      "import": "./generated/client.ts",
      "default": "./generated/client.ts"
    }
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "7.8.0",
    "@prisma/client": "7.8.0",
    "@prisma/client-runtime-utils": "^7.8.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "pg": "^8.21.0",
    "server-only": "^0.0.1",
    "undici": "^8.4.1",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "25.9.1",
    "@types/ws": "^8.18.1",
    "bufferutil": "^4.1.0",
    "dotenv": "^17.4.2",
    "prisma": "7.8.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "scripts": {
    "build": "prisma generate --no-hints --schema=./prisma/schema.prisma",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "generate": "prisma generate --no-hints --schema=./prisma/schema.prisma",
    "postinstall": "node -e \"process.exit((process.env.VERCEL_ENV || process.env.CI) && !process.env.DATABASE_URL ? 0 : 1)\" || prisma generate --no-hints --schema=./prisma/schema.prisma",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  }
}
