{
  "name": "@repo/mcp-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "start": "tsx --require ./src/preload.cts src/index.ts",
    "start:admin": "MCP_SERVER_MODE=admin tsx --require ./src/preload.cts src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@angriff36/manifest": "2.18.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "7.8.0",
    "@repo/database": "workspace:*",
    "@repo/manifest-runtime": "workspace:*",
    "@sentry/node": "^10.57.0",
    "dotenv": "^17.4.2",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "25.9.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
